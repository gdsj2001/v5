+#define V5_ROTARY_PERIOD_DEG 360.0
+#define V5_ROTARY_HALF_TURN_EPS_DEG 1.0e-5
+#define V5_G53_CODE 530
+
+static EmcPose v5_wrapped_rotary_turn_offset_deg;
+
+static int v5_valid_turn_offset_deg(double offset)
+{
+    double turns;
+    double nearest_integer;
+
+    if (!isfinite(offset)) {
+        return 0;
+    }
+    turns = offset / V5_ROTARY_PERIOD_DEG;
+    nearest_integer = floor(turns + 0.5);
+    return fabs(turns - nearest_integer) <= 1.0e-9;
+}
+
+static double v5_nearest_wrapped_equiv_deg(double target, double reference)
+{
+    double candidate;
+    double turns;
+
+    turns = floor(((reference - target) / V5_ROTARY_PERIOD_DEG) + 0.5);
+    candidate = target + (turns * V5_ROTARY_PERIOD_DEG);
+    if (fabs((candidate - reference) - (V5_ROTARY_PERIOD_DEG / 2.0)) <=
+        V5_ROTARY_HALF_TURN_EPS_DEG) {
+        candidate -= V5_ROTARY_PERIOD_DEG;
+    }
+    return candidate;
+}
+
+static int v5_prepare_wrapped_rotary_axis(double logical_target,
+                                          double reference,
+                                          double current_offset,
+                                          int phase_nearest,
+                                          double *motion_target,
+                                          double *candidate_offset)
+{
+    double prepared_target;
+    double prepared_offset = current_offset;
+
+    if (!isfinite(logical_target) || !v5_valid_turn_offset_deg(current_offset)) {
+        return -1;
+    }
+    prepared_target = logical_target + current_offset;
+    if (!isfinite(prepared_target)) {
+        return -1;
+    }
+    if (phase_nearest && fabs(logical_target) < V5_ROTARY_PERIOD_DEG) {
+        double nearest_target;
+
+        if (!isfinite(reference)) {
+            return -1;
+        }
+        nearest_target = v5_nearest_wrapped_equiv_deg(prepared_target, reference);
+        prepared_offset += nearest_target - prepared_target;
+        prepared_target = nearest_target;
+    }
+    if (!v5_valid_turn_offset_deg(prepared_offset)) {
+        return -1;
+    }
+    *motion_target = prepared_target;
+    *candidate_offset = prepared_offset;
+    return 0;
+}
+
+static int v5_is_absolute_phase_traverse(int motion_type,
+                                         const struct state_tag_t *tag)
+{
+    int absolute_mode;
+    int machine_coordinates;
+
+    if (motion_type != EMC_MOTION_TYPE_TRAVERSE || !tag) {
+        return 0;
+    }
+    absolute_mode =
+        (tag->packed_flags & (1UL << GM_FLAG_DISTANCE_MODE)) != 0;
+    machine_coordinates = tag->fields[GM_FIELD_G_MODE_0] == V5_G53_CODE;
+    return absolute_mode || machine_coordinates;
+}
+
+static int v5_prepare_wrapped_rotary_target(const EmcPose *logical_target,
+                                            int phase_nearest,
+                                            EmcPose *motion_target,
+                                            EmcPose *candidate_offset)
+{
+    EmcPose reference;
+
+    if (!logical_target || !motion_target || !candidate_offset) {
+        return -1;
+    }
+    *motion_target = *logical_target;
+    *candidate_offset = v5_wrapped_rotary_turn_offset_deg;
+    if (!v5_wrapped_rotary_mask) {
+        return 0;
+    }
+
+    reference = emcmotInternal->coord_tp.goalPos;
+    if (v5_wrapped_rotary_mask & (1 << 3)) {
+        if (!isfinite(reference.a)) {
+            reference.a = emcmotStatus->carte_pos_cmd.a;
+        }
+        if (v5_prepare_wrapped_rotary_axis(
+                logical_target->a, reference.a,
+                v5_wrapped_rotary_turn_offset_deg.a, phase_nearest,
+                &motion_target->a, &candidate_offset->a) < 0) {
+            return -1;
+        }
+    }
+    if (v5_wrapped_rotary_mask & (1 << 4)) {
+        if (!isfinite(reference.b)) {
+            reference.b = emcmotStatus->carte_pos_cmd.b;
+        }
+        if (v5_prepare_wrapped_rotary_axis(
+                logical_target->b, reference.b,
+                v5_wrapped_rotary_turn_offset_deg.b, phase_nearest,
+                &motion_target->b, &candidate_offset->b) < 0) {
+            return -1;
+        }
+    }
+    if (v5_wrapped_rotary_mask & (1 << 5)) {
+        if (!isfinite(reference.c)) {
+            reference.c = emcmotStatus->carte_pos_cmd.c;
+        }
+        if (v5_prepare_wrapped_rotary_axis(
+                logical_target->c, reference.c,
+                v5_wrapped_rotary_turn_offset_deg.c, phase_nearest,
+                &motion_target->c, &candidate_offset->c) < 0) {
+            return -1;
+        }
+    }
+    return 0;
+}
+
+static void v5_commit_wrapped_rotary_turn_offset(const EmcPose *candidate_offset)
+{
+    v5_wrapped_rotary_turn_offset_deg = *candidate_offset;
+}
+
+void v5_reset_wrapped_rotary_turn_offsets(void)
+{
+    v5_wrapped_rotary_turn_offset_deg.a = 0.0;
+    v5_wrapped_rotary_turn_offset_deg.b = 0.0;
+    v5_wrapped_rotary_turn_offset_deg.c = 0.0;
+}
