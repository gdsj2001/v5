# v5 BUS/EtherCAT native HAL.  Physical slots stay s0..s4; the resident
# clean-restart mapping atomically routes them to logical LinuxCNC joints.

loadrt [RTCP]KINS_MODULE coordinates=[RTCP]KINS_COORDINATES sparm=identityfirst
loadrt [EMCMOT]TPMOD
loadrt [EMCMOT]HOMEMOD
loadrt [EMCMOT]EMCMOT \
    servo_period_nsec=[EMCMOT]SERVO_PERIOD \
    num_joints=[KINS]JOINTS \
    v5_wrapped_rotary_mask=[RTCP]WRAPPED_ROTARY_MASK \
    v5_wcheckpoint_command_raw_bits=[AXIS_A]WCHECKPOINT_COMMAND_RAW_BITS,[AXIS_B]WCHECKPOINT_COMMAND_RAW_BITS,[AXIS_C]WCHECKPOINT_COMMAND_RAW_BITS \
    v5_wcheckpoint_feedback_raw_bits=[AXIS_A]WCHECKPOINT_FEEDBACK_RAW_BITS,[AXIS_B]WCHECKPOINT_FEEDBACK_RAW_BITS,[AXIS_C]WCHECKPOINT_FEEDBACK_RAW_BITS \
    v5_wcheckpoint_command_raw_signed=[AXIS_A]WCHECKPOINT_COMMAND_RAW_SIGNED,[AXIS_B]WCHECKPOINT_COMMAND_RAW_SIGNED,[AXIS_C]WCHECKPOINT_COMMAND_RAW_SIGNED \
    v5_wcheckpoint_feedback_raw_signed=[AXIS_A]WCHECKPOINT_FEEDBACK_RAW_SIGNED,[AXIS_B]WCHECKPOINT_FEEDBACK_RAW_SIGNED,[AXIS_C]WCHECKPOINT_FEEDBACK_RAW_SIGNED \
    v5_wcheckpoint_command_modulus_hi=[AXIS_A]WCHECKPOINT_COMMAND_MODULUS_HI,[AXIS_B]WCHECKPOINT_COMMAND_MODULUS_HI,[AXIS_C]WCHECKPOINT_COMMAND_MODULUS_HI \
    v5_wcheckpoint_command_modulus_lo=[AXIS_A]WCHECKPOINT_COMMAND_MODULUS_LO,[AXIS_B]WCHECKPOINT_COMMAND_MODULUS_LO,[AXIS_C]WCHECKPOINT_COMMAND_MODULUS_LO \
    v5_wcheckpoint_feedback_modulus_hi=[AXIS_A]WCHECKPOINT_FEEDBACK_MODULUS_HI,[AXIS_B]WCHECKPOINT_FEEDBACK_MODULUS_HI,[AXIS_C]WCHECKPOINT_FEEDBACK_MODULUS_HI \
    v5_wcheckpoint_feedback_modulus_lo=[AXIS_A]WCHECKPOINT_FEEDBACK_MODULUS_LO,[AXIS_B]WCHECKPOINT_FEEDBACK_MODULUS_LO,[AXIS_C]WCHECKPOINT_FEEDBACK_MODULUS_LO \
    v5_wcheckpoint_counts_per_rev=[AXIS_A]WCHECKPOINT_COUNTS_PER_REV,[AXIS_B]WCHECKPOINT_COUNTS_PER_REV,[AXIS_C]WCHECKPOINT_COUNTS_PER_REV \
    v5_wcheckpoint_reducer_num=[AXIS_A]MOTOR_REV,[AXIS_B]MOTOR_REV,[AXIS_C]MOTOR_REV \
    v5_wcheckpoint_reducer_den=[AXIS_A]LOAD_REV,[AXIS_B]LOAD_REV,[AXIS_C]LOAD_REV \
    v5_wcheckpoint_drive_periodic=[AXIS_A]WCHECKPOINT_DRIVE_PERIODIC,[AXIS_B]WCHECKPOINT_DRIVE_PERIODIC,[AXIS_C]WCHECKPOINT_DRIVE_PERIODIC
loadrt cia402 count=5
loadrt v5_bus_axis_router
loadrt bitslice names=j0-din,j1-din,j2-din,j3-din,j4-din personality=31,31,31,31,31
loadrt mux2 count=1
loadrt or2 count=2
loadrt not count=1
loadrt and2 count=1
loadrt v5_safety_latch

loadusr -W lcec_conf /opt/8ax/v5/linuxcnc/hal/ethercat-conf-2ms.xml
loadusr -Wn v5_native_hal_owner /usr/bin/v5_native_hal_owner \
    --model=[RTCP]MODEL \
    --kins-module=[RTCP]KINS_MODULE \
    --rtcp-default=[RTCP]DEFAULT_ACTIVE \
    --g53-a-y=[RTCP]G53_A_Y \
    --g53-a-z=[RTCP]G53_A_Z \
    --g53-b-x=[RTCP]G53_B_X \
    --g53-b-z=[RTCP]G53_B_Z \
    --g53-c-x=[RTCP]G53_C_X \
    --g53-c-y=[RTCP]G53_C_Y
loadrt lcec

# Physical feedback is routed before logical cia402 read; logical commands are
# routed after cia402 write and before the physical EtherCAT write.
addf lcec.read-all servo-thread
addf v5-bus-axis-router.read servo-thread
addf cia402.0.read-all servo-thread
addf cia402.1.read-all servo-thread
addf cia402.2.read-all servo-thread
addf cia402.3.read-all servo-thread
addf cia402.4.read-all servo-thread
addf j0-din servo-thread
addf j1-din servo-thread
addf j2-din servo-thread
addf j3-din servo-thread
addf j4-din servo-thread
addf v5-safety-latch.0 servo-thread
addf or2.0 servo-thread
addf or2.1 servo-thread
addf not.0 servo-thread
addf and2.0 servo-thread
addf mux2.0 servo-thread
addf motion-command-handler servo-thread
addf motion-controller servo-thread
addf cia402.0.write-all servo-thread
addf cia402.1.write-all servo-thread
addf cia402.2.write-all servo-thread
addf cia402.3.write-all servo-thread
addf cia402.4.write-all servo-thread
addf v5-bus-axis-router.write servo-thread
addf lcec.write-all servo-thread

net v5-safety-force v5-native-hal-owner.safety-force => v5-safety-latch.0.force
net v5-safety-reset v5-native-hal-owner.safety-reset => v5-safety-latch.0.reset
net v5-safety-heartbeat v5-native-hal-owner.heartbeat => v5-safety-latch.0.heartbeat
net v5-safety-estop-active v5-safety-latch.0.estop-active => v5-native-hal-owner.safety-estop-active motion.v5-bus-home-estop-active
net v5-safety-actual-valid v5-native-hal-owner.safety-actual-valid => motion.v5-bus-home-safety-actual-valid
net estop-loop v5-safety-latch.0.estop-ok => iocontrol.0.emc-enable-in
net v5-machine-enabled motion.motion-enabled => v5-native-hal-owner.machine-enabled motion.v5-bus-home-machine-enabled

net tool-change-loop iocontrol.0.tool-change => iocontrol.0.tool-changed
net tool-prepare-loop iocontrol.0.tool-prepare => iocontrol.0.tool-prepared
setp iocontrol.0.lube_level TRUE

setp motion.digital-in-00 TRUE
setp mux2.0.in0 0
setp mux2.0.in1 1
net v5-rtcp-ui-request v5-native-hal-owner.rtcp-ui-request => or2.0.in0
net v5-rtcp-gcode-request motion.digital-out-00 => v5-native-hal-owner.rtcp-gcode-request or2.0.in1
net v5-rtcp-owner-force-off v5-native-hal-owner.rtcp-force-off => motion.v5-bus-home-rtcp-force-latched or2.1.in0
net v5-home-rtcp-force-off motion.v5-bus-home-rtcp-force-off => v5-native-hal-owner.home-rtcp-force-off or2.1.in1
net v5-home-rtcp-request-transaction motion.v5-bus-home-rtcp-request-transaction => v5-native-hal-owner.home-rtcp-req-txn
net v5-home-rtcp-ack-transaction v5-native-hal-owner.home-rtcp-ack-transaction => motion.v5-bus-home-rtcp-latched-transaction
net v5-rtcp-force-off or2.1.out => not.0.in
net v5-rtcp-allow not.0.out => and2.0.in1
net v5-rtcp-requested or2.0.out => and2.0.in0
net v5-rtcp-selected and2.0.out => mux2.0.sel
net re-switchkins-select mux2.0.out => motion.switchkins-type v5-native-hal-owner.rtcp-actual motion.v5-bus-home-rtcp-active
net v5-rtcp-actual-valid v5-native-hal-owner.rtcp-actual-valid => motion.v5-bus-home-rtcp-actual-valid

net v5-wcheckpoint-a-logical motion.v5-wcheckpoint-a-logical-counts => v5-native-hal-owner.wcp-a-logical-counts
net v5-wcheckpoint-a-base motion.v5-wcheckpoint-a-base-counts => v5-native-hal-owner.wcp-a-base-counts motion.v5-bus-home-wcp-a-base-counts
net v5-wcheckpoint-a-runtime motion.v5-wcheckpoint-a-runtime-counts => v5-native-hal-owner.wcp-a-runtime-counts
net v5-wcheckpoint-a-generation motion.v5-wcheckpoint-a-generation => v5-native-hal-owner.wcp-a-generation motion.v5-bus-home-wcp-a-generation
net v5-wcheckpoint-a-valid motion.v5-wcheckpoint-a-valid => v5-native-hal-owner.wcp-a-valid motion.v5-bus-home-wcp-a-valid
net v5-wcheckpoint-b-logical motion.v5-wcheckpoint-b-logical-counts => v5-native-hal-owner.wcp-b-logical-counts
net v5-wcheckpoint-b-base motion.v5-wcheckpoint-b-base-counts => v5-native-hal-owner.wcp-b-base-counts motion.v5-bus-home-wcp-b-base-counts
net v5-wcheckpoint-b-runtime motion.v5-wcheckpoint-b-runtime-counts => v5-native-hal-owner.wcp-b-runtime-counts
net v5-wcheckpoint-b-generation motion.v5-wcheckpoint-b-generation => v5-native-hal-owner.wcp-b-generation motion.v5-bus-home-wcp-b-generation
net v5-wcheckpoint-b-valid motion.v5-wcheckpoint-b-valid => v5-native-hal-owner.wcp-b-valid motion.v5-bus-home-wcp-b-valid
net v5-wcheckpoint-c-logical motion.v5-wcheckpoint-c-logical-counts => v5-native-hal-owner.wcp-c-logical-counts
net v5-wcheckpoint-c-base motion.v5-wcheckpoint-c-base-counts => v5-native-hal-owner.wcp-c-base-counts motion.v5-bus-home-wcp-c-base-counts
net v5-wcheckpoint-c-runtime motion.v5-wcheckpoint-c-runtime-counts => v5-native-hal-owner.wcp-c-runtime-counts
net v5-wcheckpoint-c-generation motion.v5-wcheckpoint-c-generation => v5-native-hal-owner.wcp-c-generation motion.v5-bus-home-wcp-c-generation
net v5-wcheckpoint-c-valid motion.v5-wcheckpoint-c-valid => v5-native-hal-owner.wcp-c-valid motion.v5-bus-home-wcp-c-valid

# One atomically committed resident table feeds both the crossbar and Home.
net v5-home-table-valid v5-native-hal-owner.home-table-mapping-valid => v5-bus-axis-router.table-mapping-valid motion.v5-bus-home-config-mapping-valid
net v5-home-table-generation v5-native-hal-owner.home-table-map-gen => v5-bus-axis-router.staged-mapping-generation motion.v5-bus-home-config-mapping-generation
net v5-home-table-active-mask v5-native-hal-owner.home-table-active-mask => v5-bus-axis-router.expected-active-mask motion.v5-bus-home-config-active-mask
net v5-home-table-commit v5-native-hal-owner.home-table-commit-seq => v5-bus-axis-router.mapping-commit-seq motion.v5-bus-home-config-commit-seq

net v5-router-valid v5-bus-axis-router.mapping-valid => v5-native-hal-owner.home-router-mapping-valid motion.v5-bus-home-router-mapping-valid
net v5-router-generation v5-bus-axis-router.latched-mapping-generation => v5-native-hal-owner.home-router-map-gen motion.v5-bus-home-router-mapping-generation
net v5-router-active-mask v5-bus-axis-router.latched-active-mask => v5-native-hal-owner.home-router-active-mask motion.v5-bus-home-router-active-mask
net v5-router-commit v5-bus-axis-router.latched-commit-seq => v5-native-hal-owner.home-router-commit-seq motion.v5-bus-home-router-commit-seq
net v5-router-rejected-commit v5-bus-axis-router.rejected-commit-seq => v5-native-hal-owner.home-router-reject-seq

net v5-home-j0-config-valid v5-native-hal-owner.home-config-valid-00 => v5-bus-axis-router.joint-config-valid-00 joint.0.v5-bus-home-config-valid
net v5-home-j0-status-slot v5-native-hal-owner.home-status-slot-00 => joint.0.v5-bus-home-status-slot
net v5-home-j0-axis-code v5-native-hal-owner.home-axis-code-00 => joint.0.v5-bus-home-axis-code
net v5-home-j0-slave v5-native-hal-owner.home-slave-position-00 => v5-bus-axis-router.joint-slave-position-00 joint.0.v5-bus-home-slave-position
net v5-home-j0-generation v5-native-hal-owner.home-mapping-generation-00 => v5-bus-axis-router.joint-mapping-generation-00 joint.0.v5-bus-home-mapping-generation
net v5-home-j0-zero v5-native-hal-owner.home-zero-counts-00 => v5-bus-axis-router.joint-zero-counts-00
net v5-home-j0-scale v5-native-hal-owner.home-counts-per-unit-00 => joint.0.v5-bus-home-counts-per-unit
net v5-home-j1-config-valid v5-native-hal-owner.home-config-valid-01 => v5-bus-axis-router.joint-config-valid-01 joint.1.v5-bus-home-config-valid
net v5-home-j1-status-slot v5-native-hal-owner.home-status-slot-01 => joint.1.v5-bus-home-status-slot
net v5-home-j1-axis-code v5-native-hal-owner.home-axis-code-01 => joint.1.v5-bus-home-axis-code
net v5-home-j1-slave v5-native-hal-owner.home-slave-position-01 => v5-bus-axis-router.joint-slave-position-01 joint.1.v5-bus-home-slave-position
net v5-home-j1-generation v5-native-hal-owner.home-mapping-generation-01 => v5-bus-axis-router.joint-mapping-generation-01 joint.1.v5-bus-home-mapping-generation
net v5-home-j1-zero v5-native-hal-owner.home-zero-counts-01 => v5-bus-axis-router.joint-zero-counts-01
net v5-home-j1-scale v5-native-hal-owner.home-counts-per-unit-01 => joint.1.v5-bus-home-counts-per-unit
net v5-home-j2-config-valid v5-native-hal-owner.home-config-valid-02 => v5-bus-axis-router.joint-config-valid-02 joint.2.v5-bus-home-config-valid
net v5-home-j2-status-slot v5-native-hal-owner.home-status-slot-02 => joint.2.v5-bus-home-status-slot
net v5-home-j2-axis-code v5-native-hal-owner.home-axis-code-02 => joint.2.v5-bus-home-axis-code
net v5-home-j2-slave v5-native-hal-owner.home-slave-position-02 => v5-bus-axis-router.joint-slave-position-02 joint.2.v5-bus-home-slave-position
