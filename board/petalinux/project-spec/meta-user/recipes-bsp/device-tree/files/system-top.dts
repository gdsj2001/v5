		drm_pl_disp_hdmi {
			compatible = "xlnx,pl-disp";
			status = "disabled";
			dmas = <0x28 0x0>;
			dma-names = "dma0";
			xlnx,vformat = "BG24";
			xlnx,bridge = <0x29>;

			ports {
				#address-cells = <0x1>;
				#size-cells = <0x0>;

				port@0 {
					reg = <0x0>;

