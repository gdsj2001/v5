	chosen {
		bootargs = "console=ttyPS0,115200 cma=50M earlycon root=/dev/mmcblk0p2 rw rootwait";
		stdout-path = "serial0:115200n8";
	};

	aliases {
		ethernet0 = "/amba/ethernet@e000b000";
		ethernet1 = "/amba/ethernet@e000c000";
		i2c0 = "/amba/i2c@e0004000";
		i2c1 = "/amba/i2c@e0005000";
		i2c2 = "/amba_pl/i2c@41600000";
		serial0 = "/amba/serial@e0000000";
		serial1 = "/amba/serial@e0001000";
		spi0 = "/amba/spi@e000d000";
	};

	memory {
		device_type = "memory";
		reg = <0x0 0x40000000>;
	};

	leds {
		compatible = "gpio-leds";

		gpio-led1 {
			label = "led1";
			gpios = <0x9 0x36 0x0>;
			default-state = "on";
		};

		gpio-led2 {
			label = "led2";
			gpios = <0x9 0x0 0x0>;
			linux,default-trigger = "heartbeat";
		};

		gpio-led3 {
			label = "pl_led0";
			gpios = <0x30 0x0 0x0 0x0>;
			default-state = "on";
		};

		gpio-led4 {
			label = "pl_led1";
			gpios = <0x30 0x1 0x0 0x0>;
			linux,default-trigger = "timer";
		};

		gpio-led5 {
			label = "ps_led0";
			gpios = <0x9 0x7 0x0>;
			default-state = "on";
		};

		gpio-led6 {
			label = "ps_led1";
			gpios = <0x9 0x8 0x0>;
			linux,default-trigger = "timer";
		};
	};

	keys {
		compatible = "gpio-keys";
		autorepeat;

		gpio-key1 {
			label = "pl_key0";
			gpios = <0x9 0x37 0x1>;
			linux,code = <0x69>;
			gpio-key,wakeup;
			autorepeat;
		};

		gpio-key2 {
			label = "pl_key1";
			gpios = <0x9 0x38 0x1>;
			linux,code = <0x6a>;
			gpio-key,wakeup;
			autorepeat;
		};

		gpio-key3 {
			label = "ps_key1";
			gpios = <0x9 0xc 0x1>;
			linux,code = <0x67>;
			gpio-key,wakeup;
			autorepeat;
		};

		gpio-key4 {
			label = "ps_key2";
			gpios = <0x9 0xb 0x1>;
			linux,code = <0x6c>;
			gpio-key,wakeup;
			autorepeat;
		};

		touch-key {
			label = "touch_key";
			gpios = <0x9 0x39 0x0>;
			linux,code = <0x1c>;
			gpio-key,wakeup;
			autorepeat;
		};
	};

	beep {
		compatible = "gpio-beeper";
		status = "disabled";
		gpios = <0x9 0x3a 0x0>;
	};

	phy0@e0002000 {
		compatible = "ulpi-phy";
		#phy-cells = <0x0>;
		reg = <0xe0002000 0x1000>;
		view-port = <0x170>;
		drv-vbus;
		phandle = <0xd>;
	};
};
