From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: V5 Project <v5@example.invalid>
Date: Sat, 16 May 2026 14:20:00 +0800
Subject: [PATCH] v5: split mixed domain datagrams

The V5 LinuxCNC native EtherCAT path runs cyclic process data through
IgH/lcec. On the Zynq GEM generic backend with the SV630N chain, mixed
input/output domains were emitted as a single LRW datagram and the slaves
dropped back to INIT with WKC 0 during process-data startup.

Keep the native IgH/LinuxCNC path, but split a domain datagram when the next
FMMU changes direction. This emits native LWR frames for outputs and native
LRD frames for inputs instead of a mixed LRW frame.
---
 master/domain.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/master/domain.c b/master/domain.c
index 3333333..4444444 100644
--- a/master/domain.c
+++ b/master/domain.c
@@ -204,6 +204,7 @@ int ec_domain_finish(
     unsigned int datagram_count;
     unsigned int datagram_used[EC_DIR_COUNT];
     ec_fmmu_config_t *fmmu;
+    unsigned int datagram_dir_mask;
     const ec_fmmu_config_t *datagram_first_fmmu = NULL;
     const ec_datagram_pair_t *datagram_pair;
     int ret;
@@ -230,6 +231,7 @@ int ec_domain_finish(
     datagram_count = 0;
     datagram_used[EC_DIR_OUTPUT] = 0;
     datagram_used[EC_DIR_INPUT] = 0;
+    datagram_dir_mask = 0;
 
     if (!list_empty(&domain->fmmu_configs)) {
         datagram_first_fmmu =
@@ -244,7 +246,9 @@ int ec_domain_finish(
 
         // If the current FMMU's data do not fit in the current datagram,
         // allocate a new one.
-        if (datagram_size + fmmu->data_size > EC_MAX_DATA_SIZE) {
+        if (datagram_size &&
+                (datagram_size + fmmu->data_size > EC_MAX_DATA_SIZE ||
+                 !(datagram_dir_mask & (1U << fmmu->dir)))) {
             ret = ec_domain_add_datagram_pair(domain,
                     domain->logical_base_address + datagram_offset,
                     datagram_size, domain->data + datagram_offset,
@@ -258,6 +262,7 @@ int ec_domain_finish(
             datagram_used[EC_DIR_OUTPUT] = 0;
             datagram_used[EC_DIR_INPUT] = 0;
             datagram_first_fmmu = fmmu;
+            datagram_dir_mask = 0;
         }
 
         // Increment Input/Output counter to determine datagram types
@@ -267,6 +272,9 @@ int ec_domain_finish(
             datagram_used[fmmu->dir]++;
         }
 
+        // V5 native EtherCAT: keep datagrams single-direction (LWR/LRD).
+        datagram_dir_mask |= 1U << fmmu->dir;
+
         datagram_size += fmmu->data_size;
     }
 
