From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: V5 Project <v5@example.invalid>
Date: Thu, 23 Jul 2026 15:18:00 +0800
Subject: [PATCH] v5: snapshot cyclic write segments on first hard event

Keep the hard-event recorder bounded and allocation-free while capturing the
current lcec.write breakdown. This distinguishes wake/prelock delay, the
master mutex, EtherCAT preparation, and the device send path without tracing
or realtime logging.
---
 src/lcec.h      |  5 +++++
 src/lcec_main.c | 47 +++++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 52 insertions(+)

diff --git a/src/lcec.h b/src/lcec.h
--- a/src/lcec.h
+++ b/src/lcec.h
@@ -221,6 +221,11 @@ typedef struct lcec_master_data {
   hal_u32_t *runtime_period_event_dc_age_cycles;
   hal_u32_t *runtime_period_event_app_time_hi;
   hal_u32_t *runtime_period_event_app_time_lo;
+  hal_u32_t *runtime_period_event_write_prelock_ns;
+  hal_u32_t *runtime_period_event_write_lock_wait_ns;
+  hal_u32_t *runtime_period_event_write_prepare_ns;
+  hal_u32_t *runtime_period_event_write_send_ns;
+  hal_u32_t *runtime_period_event_write_total_ns;
   hal_s32_t *drift_mode;            // Input: 0=simple, 1=manual
   hal_s32_t *pll_drift;            // Input: debug offset added to PLL correction (ns)
   hal_s32_t *pll_final;            // Output: final PLL correction value sent to rtapi (ns)
diff --git a/src/lcec_main.c b/src/lcec_main.c
--- a/src/lcec_main.c
+++ b/src/lcec_main.c
@@ -85,6 +85,11 @@ static const lcec_pindesc_t master_pins[] = {
     {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_dc_age_cycles), "%s.runtime-period-event-dc-age-cycles"},
     {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_app_time_hi), "%s.runtime-period-event-app-time-hi"},
     {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_app_time_lo), "%s.runtime-period-event-app-time-lo"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_write_prelock_ns), "%s.runtime-period-event-write-prelock-ns"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_write_lock_wait_ns), "%s.runtime-period-event-write-lock-wait-ns"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_write_prepare_ns), "%s.runtime-period-event-write-prepare-ns"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_write_send_ns), "%s.runtime-period-event-write-send-ns"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_period_event_write_total_ns), "%s.runtime-period-event-write-total-ns"},
     {HAL_S32, HAL_IN, offsetof(lcec_master_data_t, drift_mode), "%s.drift-mode"},
     {HAL_S32, HAL_IN, offsetof(lcec_master_data_t, pll_drift), "%s.pll-drift"},
     {HAL_S32, HAL_OUT, offsetof(lcec_master_data_t, pll_final), "%s.pll-final"},
@@ -1201,6 +1206,11 @@ static int lcec_activate_master(lcec_master_t *master) {
   *(master->hal_data->runtime_period_event_dc_age_cycles) = 0;
   *(master->hal_data->runtime_period_event_app_time_hi) = 0;
   *(master->hal_data->runtime_period_event_app_time_lo) = 0;
+  *(master->hal_data->runtime_period_event_write_prelock_ns) = 0;
+  *(master->hal_data->runtime_period_event_write_lock_wait_ns) = 0;
+  *(master->hal_data->runtime_period_event_write_prepare_ns) = 0;
+  *(master->hal_data->runtime_period_event_write_send_ns) = 0;
+  *(master->hal_data->runtime_period_event_write_total_ns) = 0;
   master->hal_data->runtime_period_last_valid = 0;
   master->dc_ref = 0;
   if (!master->sync_to_ref_clock) {
@@ -1340,6 +1350,11 @@ void lcec_read_master(void *arg, long period) {
       slave->proc_read(slave, period);
     }
   }
+}
+
+static uint32_t lcec_elapsed_ns(long long start, long long end) {
+  uint64_t elapsed = end > start ? (uint64_t)(end - start) : 0;
+  return elapsed > UINT32_MAX ? UINT32_MAX : (uint32_t)elapsed;
 }
 
 /// @brief Write all output pins on a master and its slaves.
@@ -1348,6 +1363,11 @@ void lcec_write_master(void *arg, long period) {
   lcec_slave_t *slave;
   uint64_t app_time;
   long long now;
+  long long write_start;
+  long long write_lock_start;
+  long long write_lock_acquired;
+  long long write_send_start;
+  long long write_send_done;
 #ifdef RTAPI_TASK_PLL_SUPPORT
   long long ref;
   lcec_master_data_t *hal_data;
@@ -1363,6 +1383,8 @@ void lcec_write_master(void *arg, long period) {
     return;
   }
 
+  write_start = rtapi_get_time();
+
   // process slaves
   for (slave = master->first_slave; slave != NULL; slave = slave->next) {
     if (slave->proc_write != NULL) {
@@ -1375,8 +1397,11 @@ void lcec_write_master(void *arg, long period) {
   ref = rtapi_task_pll_get_reference();
 #endif
 
+  write_lock_start = rtapi_get_time();
+
   // send process data
   rtapi_mutex_get(&master->mutex);
+  write_lock_acquired = rtapi_get_time();
   ecrt_domain_queue(master->domain);
 
   // update application time
@@ -1431,7 +1456,9 @@ void lcec_write_master(void *arg, long period) {
   ecrt_master_sync_slave_clocks(master->master);
 
   // send domain data
+  write_send_start = rtapi_get_time();
   ecrt_master_send(master->master);
+  write_send_done = rtapi_get_time();
   rtapi_mutex_give(&master->mutex);
 
 #ifdef RTAPI_TASK_PLL_SUPPORT
@@ -1466,6 +1493,11 @@ void lcec_write_master(void *arg, long period) {
     *(hal_data->runtime_period_event_dc_age_cycles) = 0;
     *(hal_data->runtime_period_event_app_time_hi) = 0;
     *(hal_data->runtime_period_event_app_time_lo) = 0;
+    *(hal_data->runtime_period_event_write_prelock_ns) = 0;
+    *(hal_data->runtime_period_event_write_lock_wait_ns) = 0;
+    *(hal_data->runtime_period_event_write_prepare_ns) = 0;
+    *(hal_data->runtime_period_event_write_send_ns) = 0;
+    *(hal_data->runtime_period_event_write_total_ns) = 0;
   }
   if (!hal_data->runtime_period_last_valid) {
     hal_data->runtime_app_time_last = app_time;
@@ -1546,6 +1578,16 @@ void lcec_write_master(void *arg, long period) {
         (uint32_t)(app_time >> 32);
     *(hal_data->runtime_period_event_app_time_lo) =
         (uint32_t)(app_time & UINT32_MAX);
+    *(hal_data->runtime_period_event_write_prelock_ns) =
+        lcec_elapsed_ns(write_start, write_lock_start);
+    *(hal_data->runtime_period_event_write_lock_wait_ns) =
+        lcec_elapsed_ns(write_lock_start, write_lock_acquired);
+    *(hal_data->runtime_period_event_write_prepare_ns) =
+        lcec_elapsed_ns(write_lock_acquired, write_send_start);
+    *(hal_data->runtime_period_event_write_send_ns) =
+        lcec_elapsed_ns(write_send_start, write_send_done);
+    *(hal_data->runtime_period_event_write_total_ns) =
+        lcec_elapsed_ns(write_start, write_send_done);
     *(hal_data->runtime_period_event_valid) = 1;
   }
   
-- 
2.39.2
