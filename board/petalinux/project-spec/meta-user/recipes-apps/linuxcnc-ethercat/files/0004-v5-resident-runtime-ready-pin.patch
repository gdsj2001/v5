From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: V5 Project <v5@example.invalid>
Date: Sun, 19 Jul 2026 18:20:00 +0800
Subject: [PATCH] v5: publish resident EtherCAT runtime readiness

The shell lifecycle currently starts many halcmd processes to reconstruct a
two-sample WKC/DC decision. Those diagnostic attaches contend with the HAL
runtime during cold startup and can themselves extend or disturb convergence.

Move the continuous proof into the resident 2 ms lcec cycle. A master becomes
runtime-ready only after every configured slave is OP, the domain WKC is
complete, DC is phased and the reference-clock sample is fresh for 100
consecutive cycles. Any failed condition clears readiness in the same cycle;
the generation advances only on a later recovery.
---
 src/lcec.h      |  5 +++++
 src/lcec_main.c | 44 ++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 49 insertions(+)

diff --git a/src/lcec.h b/src/lcec.h
index 1817cbbbf..add34c842 100644
--- a/src/lcec.h
+++ b/src/lcec.h
@@ -182,10 +182,12 @@ typedef struct lcec_master_data {
   hal_bit_t *all_op;
   hal_u32_t *domain_working_counter; // Current ecrt Domain working counter
   hal_bit_t *domain_wc_complete;     // Current ecrt Domain WC state is COMPLETE
   hal_u32_t *domain_wc_ok_seq;       // Increments for every complete resident cycle
   hal_u32_t *domain_wc_error_count;  // Total incomplete resident cycles
+  hal_bit_t *runtime_ready;          // Continuous resident OP/WKC/DC proof
+  hal_u32_t *runtime_ready_generation; // Increments on each recovery to ready
 #ifdef RTAPI_TASK_PLL_SUPPORT
   hal_s32_t *pll_err;
   hal_s32_t *pll_out;
   hal_u32_t pll_step;
   hal_u32_t pll_max_err;
@@ -246,10 +248,13 @@ typedef struct lcec_master {
   ec_master_state_t ms;
   ec_domain_state_t ds;
   int activated;                    // Flag: master has been activated (0=not yet, 1=activated)
   int rt_activated;                 // Activation happened in the first resident read cycle
   int activation_failed;            // Activation failed once; cyclic code must not retry it
+  uint32_t configured_slave_count;  // Expected slaves owned by this master
+  uint32_t runtime_ready_stable_cycles; // Consecutive healthy resident cycles
+  uint32_t runtime_ready_generation; // Monotonic source for the HAL pin
 #ifdef RTAPI_TASK_PLL_SUPPORT
   uint64_t dc_ref;
   uint64_t dc_ref_time;          // DC reference time (epoch) - set on first app_time call
   uint32_t app_time_last;
   int dc_time_valid_last;         // Previous cycle's dc_time_valid (for detecting consecutive valid reads)
diff --git a/src/lcec_main.c b/src/lcec_main.c
index 7c8c9867e..279d95948 100644
--- a/src/lcec_main.c
+++ b/src/lcec_main.c
@@ -32,10 +32,12 @@
 
 MODULE_LICENSE("GPL")
 MODULE_AUTHOR("Sascha Ittner <sascha.ittner@modusoft.de>")
 MODULE_DESCRIPTION("Driver for EtherCAT devices")
 
+#define LCEC_RUNTIME_READY_STABLE_CYCLES 100U
+
 /// @brief Global HAL Pins
 static const lcec_pindesc_t master_global_pins[] = {
     {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, slaves_responding), "%s.slaves-responding"},
     {HAL_BIT, HAL_OUT, offsetof(lcec_master_data_t, state_init), "%s.state-init"},
     {HAL_BIT, HAL_OUT, offsetof(lcec_master_data_t, state_preop), "%s.state-preop"},
@@ -65,10 +67,12 @@ static const lcec_pindesc_t master_pins[] = {
     {HAL_S32, HAL_OUT, offsetof(lcec_master_data_t, phase_jitter_out), "%s.phase-jitter"},
     {HAL_S32, HAL_IN, offsetof(lcec_master_data_t, drift_mode), "%s.drift-mode"},
     {HAL_S32, HAL_IN, offsetof(lcec_master_data_t, pll_drift), "%s.pll-drift"},
     {HAL_S32, HAL_OUT, offsetof(lcec_master_data_t, pll_final), "%s.pll-final"},
 #endif
+    {HAL_BIT, HAL_OUT, offsetof(lcec_master_data_t, runtime_ready), "%s.runtime-ready"},
+    {HAL_U32, HAL_OUT, offsetof(lcec_master_data_t, runtime_ready_generation), "%s.runtime-ready-generation"},
     {HAL_TYPE_UNSPECIFIED, HAL_DIR_UNSPECIFIED, -1, NULL},
 };
 
 /// @brief Master params
 static const lcec_paramdesc_t master_params[] = {
@@ -156,10 +160,11 @@ int rtapi_app_main(void) {
     goto fail2;
   }
 
   // initialize masters
   for (master = first_master; master != NULL; master = master->next) {
+    master->configured_slave_count = 0;
     // request ethercat master
     if (!(master->master = ecrt_request_master(master->index))) {
       rtapi_print_msg(RTAPI_MSG_ERR, LCEC_MSG_PFX "requesting master %s (index %d) failed\n", master->name, master->index);
       goto fail2;
     }
@@ -175,10 +180,11 @@ int rtapi_app_main(void) {
       goto fail2;
     }
 
     // initialize slaves
     for (slave = master->first_slave; slave != NULL; slave = slave->next) {
+      master->configured_slave_count++;
       // read slave config
 
       rtapi_print_msg(RTAPI_MSG_DBG, LCEC_MSG_PFX "calling ecrt_master_slave_config for slave %s.%s\n", master->name, slave->name);
       if (!(slave->config = ecrt_master_slave_config(master->master, 0, slave->index, slave->vid, slave->pid))) {
         rtapi_print_msg(RTAPI_MSG_ERR, LCEC_MSG_PFX "fail to read slave %s.%s configuration\n", master->name, slave->name);
@@ -1070,10 +1076,14 @@ static int lcec_activate_master(lcec_master_t *master) {
   *(master->hal_data->domain_working_counter) = 0;
   *(master->hal_data->domain_wc_complete) = 0;
   *(master->hal_data->domain_wc_ok_seq) = 0;
   *(master->hal_data->domain_wc_error_count) = 0;
   memset(&master->ds, 0, sizeof(master->ds));
+  *(master->hal_data->runtime_ready) = 0;
+  *(master->hal_data->runtime_ready_generation) = 0;
+  master->runtime_ready_stable_cycles = 0;
+  master->runtime_ready_generation = 0;
 
 #ifdef RTAPI_TASK_PLL_SUPPORT
   master->dc_time_valid_last = 0;
   *(master->hal_data->dc_time_valid) = 0;
   *(master->hal_data->dc_time_ok_seq) = 0;
@@ -1462,10 +1472,38 @@ void lcec_write_master(void *arg, long period) {
   *(hal_data->pll_final) = pll_correction;
   rtapi_task_pll_set_correction(pll_correction);
   
   master->app_time_last = (uint32_t)app_time;
   master->dc_time_valid_last = dc_time_valid;
+
+  // Keep startup/status readers out of the HAL hot path: the resident cycle
+  // owns the continuous proof and publishes one fail-closed actual.
+  if (master->configured_slave_count > 0 &&
+      *(hal_data->all_op) &&
+      *(hal_data->slaves_responding) == master->configured_slave_count &&
+      *(hal_data->domain_wc_complete) &&
+      *(hal_data->dc_phased) &&
+      *(hal_data->dc_time_valid) &&
+      *(hal_data->dc_time_age_cycles) == 0) {
+    if (master->runtime_ready_stable_cycles <
+        LCEC_RUNTIME_READY_STABLE_CYCLES) {
+      master->runtime_ready_stable_cycles++;
+    }
+    if (master->runtime_ready_stable_cycles >=
+        LCEC_RUNTIME_READY_STABLE_CYCLES &&
+        !*(hal_data->runtime_ready)) {
+      if (master->runtime_ready_generation != UINT32_MAX) {
+        master->runtime_ready_generation++;
+      }
+      *(hal_data->runtime_ready_generation) =
+          master->runtime_ready_generation;
+      *(hal_data->runtime_ready) = 1;
+    }
+  } else {
+    master->runtime_ready_stable_cycles = 0;
+    *(hal_data->runtime_ready) = 0;
+  }
 #endif
 }
 
 
 #ifndef __KERNEL__
-- 
2.39.2
