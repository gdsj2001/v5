#!/bin/sh
set -eu

bind_service_init_to_cpu1() {
  cpu_list=
  while read -r key value rest; do
    if [ "$key" = "Cpus_allowed_list:" ]; then
      cpu_list=${value:-}
      break
    fi
  done <"/proc/$$/status"
  [ "$cpu_list" = "1" ] && return 0
  [ -x /usr/bin/taskset ] || {
    echo "taskset missing; service init cannot exclude CPU0" >&2
    return 1
  }
  exec /usr/bin/taskset -c 1 "$0" "$@"
}
bind_service_init_to_cpu1 "$@"


LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

UI_DAEMON=/usr/libexec/8ax/v5_lvgl_shell
RELAY_DAEMON=/usr/libexec/8ax/v5_remote_ui_relay.py
REMOTE_PACKER=/usr/libexec/8ax/v5_remote_ui_packer.so
BOOT_READY=/usr/libexec/8ax/v5_ui_boot_ready.py
BACKEND_READINESS_PROBE=/usr/libexec/8ax/v5_backend_readiness_probe
PIDFILE=/run/8ax/v5_ui_relay.pid
UI_PIDFILE=/run/8ax/v5_ui_shell.pid
RELAY_STARTFILE=/run/8ax/v5_ui_relay.start_ticks
UI_STARTFILE=/run/8ax/v5_ui_shell.start_ticks
LOGFILE=/run/8ax/v5_ui_relay.log
UI_BOOT_LOG=/run/8ax/v5_ui_boot.log
UI_READY_PATH=/run/8ax_v5_product_ui/ui_ready.json
PUBLISHER_SNAPSHOT_PATH=/run/8ax_v5_product_ui/ui_input_barrier.json
PORT=${V5_UI_REMOTE_PORT:-18080}
REMOTE_BIND=${V5_UI_REMOTE_BIND:-0.0.0.0}
REMOTE_ALLOW_CIDRS=${V5_UI_REMOTE_ALLOW_CIDRS:-127.0.0.1/32,192.168.1.0/24}
REMOTE_INPUT=${V5_UI_REMOTE_INPUT:-layout_only}
REMOTE_WIDTH=${V5_UI_REMOTE_WIDTH:-1024}
REMOTE_HEIGHT=${V5_UI_REMOTE_HEIGHT:-600}
PROJECT_ROOT=${V5_PROJECT_ROOT:-/opt/8ax/v5}
UI_INPUT_NICE=0

boot_stage() {
  stage="$1"
  awk -v stage="$stage" '{printf "V5_BOOT_STAGE stage=%s uptime_ms=%.0f\n", stage, $1 * 1000}' /proc/uptime >>"$LOGFILE"
}

read_pidfile() {
  read_pidfile_path="$1"
  [ -r "$read_pidfile_path" ] || return 1
  read_pidfile_value=$(cat "$read_pidfile_path" 2>/dev/null || true)
  case "$read_pidfile_value" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$read_pidfile_value" -gt 0 ] || return 1
  printf '%s\n' "$read_pidfile_value"
}

process_start_ticks() {
  process_start_pid="$1"
  [ -r "/proc/$process_start_pid/stat" ] || return 1
  process_start_value=$(sed -n 's/^.*) //p' "/proc/$process_start_pid/stat" 2>/dev/null | awk '{print $20}')
  case "$process_start_value" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$process_start_value" -gt 0 ] || return 1
  printf '%s\n' "$process_start_value"
}

read_startfile() {
  read_startfile_path="$1"
  [ -r "$read_startfile_path" ] || return 1
  read_startfile_value=$(cat "$read_startfile_path" 2>/dev/null || true)
  case "$read_startfile_value" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$read_startfile_value" -gt 0 ] || return 1
  printf '%s\n' "$read_startfile_value"
}

process_has_exact_arg() {
  process_arg_pid="$1"
  process_arg_expected="$2"
  [ -r "/proc/$process_arg_pid/cmdline" ] || return 1
  tr '\000' '\n' <"/proc/$process_arg_pid/cmdline" 2>/dev/null | grep -F -x -q "$process_arg_expected"
}

record_process_identity() {
  record_identity_pid="$1"
  record_identity_path="$2"
  record_identity_ticks=$(process_start_ticks "$record_identity_pid") || return 1
  printf '%s\n' "$record_identity_ticks" >"$record_identity_path"
}

process_identity_matches() {
  identity_pidfile="$1"
  identity_startfile="$2"
  identity_expected_arg="$3"
  identity_pid=$(read_pidfile "$identity_pidfile" 2>/dev/null || true)
  identity_expected_start=$(read_startfile "$identity_startfile" 2>/dev/null || true)
  [ -n "$identity_pid" ] && [ -n "$identity_expected_start" ] || return 1
  pid_running "$identity_pid" || return 1
  identity_actual_start=$(process_start_ticks "$identity_pid" 2>/dev/null || true)
  [ "$identity_actual_start" = "$identity_expected_start" ] || return 1
  process_has_exact_arg "$identity_pid" "$identity_expected_arg"
}

pid_running() {
  pid_running_value="$1"
  [ -n "$pid_running_value" ] || return 1
  kill -0 "$pid_running_value" 2>/dev/null
}

is_ui_running() {
  process_identity_matches "$UI_PIDFILE" "$UI_STARTFILE" "$UI_DAEMON"
}

is_relay_running() {
  process_identity_matches "$PIDFILE" "$RELAY_STARTFILE" "$RELAY_DAEMON"
}

is_ui_ready() {
  is_ui_running || return 1
  pid=$(read_pidfile "$UI_PIDFILE" 2>/dev/null || true)
  [ -n "$pid" ] || return 1
  boot_id=$(cat /proc/sys/kernel/random/boot_id 2>/dev/null || true)
  [ -n "$boot_id" ] || return 1
  ui_start_ticks=$(read_startfile "$UI_STARTFILE" 2>/dev/null || true)
  [ -n "$ui_start_ticks" ] || return 1
  [ -s "$UI_READY_PATH" ] || return 1
  grep -q '"schema":"v5.ui_ready.v1"' "$UI_READY_PATH" &&
    grep -q '"ready":true' "$UI_READY_PATH" &&
    grep -q "\"boot_id\":\"$boot_id\"" "$UI_READY_PATH" &&
    grep -q '"ui_instance_id":"[0-9a-f]\{8\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{4\}-[0-9a-f]\{12\}"' "$UI_READY_PATH" &&
    grep -q "\"ui_pid\":$pid" "$UI_READY_PATH" &&
    grep -q "\"ui_start_ticks\":$ui_start_ticks" "$UI_READY_PATH" &&
    grep -q '"publisher_barrier":{' "$UI_READY_PATH" &&
    grep -q '"backend_ready":{' "$UI_READY_PATH"
}

is_running() {
  is_ui_running && is_relay_running && is_ui_ready
}

set_non_microkernel_affinity() {
  pid="$1"
  [ -n "$pid" ] || return 0
  command -v taskset >/dev/null 2>&1 || return 1
  command -v renice >/dev/null 2>&1 || return 1
  cpu1_available || return 1
  taskset -a -pc 1 "$pid" >>"$LOGFILE" 2>&1 || return 1
  renice -n "$UI_INPUT_NICE" -p "$pid" >>"$LOGFILE" 2>&1 || return 1
  nice_value=$(awk '{print $19}' /proc/"$pid"/stat 2>/dev/null || true)
  [ "$nice_value" = "$UI_INPUT_NICE" ] || return 1
}

cpu1_available() {
  grep -qw 1 /sys/devices/system/cpu/online 2>/dev/null || grep -q '0-1' /sys/devices/system/cpu/online 2>/dev/null
}

set_irq_affinity_by_label() {
  label="$1"
  cpu="$2"
  [ -n "$label" ] || return 0
  [ -n "$cpu" ] || return 0
  [ -r /proc/interrupts ] || return 0
  awk -v label="$label" '$0 ~ label {irq=$1; sub(":", "", irq); print irq}' /proc/interrupts |
  while read -r irq; do
    [ -n "$irq" ] || continue
    [ -w "/proc/irq/$irq/smp_affinity_list" ] || continue
    if echo "$cpu" >"/proc/irq/$irq/smp_affinity_list" 2>/dev/null; then
      readback=$(cat "/proc/irq/$irq/smp_affinity_list" 2>/dev/null || true)
      echo "v5_ui_relay irq_affinity label=$label irq=$irq cpu=$cpu readback=$readback" >>"$LOGFILE"
    fi
  done
}

set_display_irq_affinity() {
  cpu1_available || return 0
  set_irq_affinity_by_label "xilinx_framebuffer" 1
}


wait_boot_inputs_ready() {
  expected_ini="$PROJECT_ROOT/linuxcnc/ini/v5_bus.ini"
  test -x "$BACKEND_READINESS_PROBE"
  "$BACKEND_READINESS_PROBE" --wait data --timeout-ms 120000 >>"$LOGFILE" 2>&1
  test -s "$PROJECT_ROOT/config/settings/self_parameter_table.tsv"
  test -s "$PROJECT_ROOT/config/settings/drive_parameter_table.tsv"
  python3 -c 'import json,sys; p=json.load(open(sys.argv[1])); raise SystemExit(0 if p.get("loaded") and int(p.get("profile_count") or 0)>0 and int(p.get("map_file_count") or 0)>0 else 1)' \
    /run/8ax_v5_drive/drive_profile_resident_snapshot.json
  "$BOOT_READY" --pre-ui-inputs --expected-ini "$expected_ini" \
    --publisher-snapshot-path "$PUBLISHER_SNAPSHOT_PATH" \
    --timeout 120 >>"$LOGFILE" 2>&1
}

stale_service_pids() {
  for cmdline in /proc/[0-9]*/cmdline; do
    [ -r "$cmdline" ] || continue
    pid=${cmdline#/proc/}
    pid=${pid%/cmdline}
    [ "$pid" != "$$" ] || continue
    cmd=$(tr '\000' ' ' <"$cmdline" 2>/dev/null || true)
    case "$cmd" in
      *"/usr/libexec/8ax/v5_lvgl_shell"*|*"v5_lvgl_shell --serve"*|*"/usr/libexec/8ax/v5_remote_ui_relay.py"*|*"v5_remote_ui_relay.py"*)
        echo "$pid"
        ;;
    esac
  done
}

stop_stale_processes() {
  pids=$(stale_service_pids | tr '\n' ' ')
  [ -n "$pids" ] || return 0
  for pid in $pids; do
    kill "$pid" 2>/dev/null || true
  done
  i=0
  while [ -n "$(stale_service_pids)" ] && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  pids=$(stale_service_pids | tr '\n' ' ')
  [ -n "$pids" ] || return 0
  for pid in $pids; do
    kill -KILL "$pid" 2>/dev/null || true
  done
  sleep 0.2
  pids=$(stale_service_pids | tr '\n' ' ')
  [ -z "$pids" ] || {
    echo "v5_ui_relay stale process did not stop pid=$pids" >&2
    return 1
  }
}

publish_startup_failure() {
  stage="$1"
  error="$2"
  owner_role=supervisor
  owner_pid=$$
  owner_start=$(process_start_ticks "$$") || return 1
  if is_relay_running; then
    owner_role=relay
    owner_pid=$(read_pidfile "$PIDFILE")
    owner_start=$(read_startfile "$RELAY_STARTFILE")
  fi
  "$BOOT_READY" --publish-failure \
    --ready-path "$UI_READY_PATH" \
    --startup-instance-id "$STARTUP_INSTANCE_ID" \
    --failure-owner-role "$owner_role" \
    --failure-owner-pid "$owner_pid" \
    --failure-owner-start-ticks "$owner_start" \
    --failure-stage "$stage" \
    --failure-error "$error" >>"$LOGFILE" 2>&1
}

stop_ui_only() {
  stop_pidfile "$UI_PIDFILE" "$UI_STARTFILE" "$UI_DAEMON" "v5_ui_shell" >/dev/null 2>&1 || true
}



start_service() {
  if is_running; then
    echo "v5_ui_relay already running relay_pid=$(read_pidfile "$PIDFILE") ui_pid=$(read_pidfile "$UI_PIDFILE") port=$PORT project_root=$PROJECT_ROOT"
    return 0
  fi
  test -x "$UI_DAEMON"
  test -x "$RELAY_DAEMON"
  test -r "$REMOTE_PACKER"
  test -x "$BOOT_READY"
  cpu1_available
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  command -v renice >/dev/null 2>&1
  mkdir -p /run/8ax
  mkdir -p /run/8ax_v5_product_ui
  STARTUP_INSTANCE_ID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || true)
  [ -n "$STARTUP_INSTANCE_ID" ] || {
    echo "v5_ui_relay cannot allocate startup instance identity" >&2
    return 1
  }
  rm -f "$PIDFILE" "$UI_PIDFILE" "$RELAY_STARTFILE" "$UI_STARTFILE"
  stop_stale_processes
  : >"$LOGFILE"
  : >"$UI_BOOT_LOG"
  boot_stage ui_service_start
  rm -f "$UI_READY_PATH" \
    "$PUBLISHER_SNAPSHOT_PATH" \
    /run/8ax_v5_product_ui/remote_framebuffer.bgra \
    /run/8ax_v5_product_ui/remote_dirty \
    /run/8ax_v5_product_ui/remote_input
  set_display_irq_affinity

  V5_UI_READY_PATH="$UI_READY_PATH" V5_UI_REMOTE_INPUT="$REMOTE_INPUT" \
    V5_UI_REMOTE_BIND="$REMOTE_BIND" V5_UI_REMOTE_ALLOW_CIDRS="$REMOTE_ALLOW_CIDRS" \
    V5_UI_REMOTE_PORT="$PORT" V5_UI_REMOTE_WIDTH="$REMOTE_WIDTH" V5_UI_REMOTE_HEIGHT="$REMOTE_HEIGHT" \
    setsid taskset -c 1 nice -n "$UI_INPUT_NICE" "$RELAY_DAEMON" --host "$REMOTE_BIND" --port "$PORT" \
      --allow-cidrs "$REMOTE_ALLOW_CIDRS" --width "$REMOTE_WIDTH" --height "$REMOTE_HEIGHT" \
      --ready-path "$UI_READY_PATH" --program-root "$PROJECT_ROOT/gcode/golden" >>"$LOGFILE" 2>&1 &
  echo "$!" >"$PIDFILE"
  if ! record_process_identity "$(read_pidfile "$PIDFILE")" "$RELAY_STARTFILE"; then
    echo "v5_remote_ui_relay process identity unavailable" >&2
    publish_startup_failure remote_relay_spawn "relay process identity unavailable" || true
    stop_stale_processes
    return 1
  fi
  i=0
  while [ "$i" -lt 50 ]; do
    if is_relay_running && [ -p /run/8ax_v5_product_ui/remote_dirty ] && \
       wget -q -O /tmp/v5_ui_boot_diagnostics.json "http://127.0.0.1:$PORT/remote/diagnostics"; then
      break
    fi
    i=$((i + 1))
    sleep 0.1
  done
  if ! is_relay_running || [ ! -p /run/8ax_v5_product_ui/remote_dirty ]; then
    echo "v5_remote_ui_relay failed to establish pre-ready dirty reader" >&2
    tail -n 40 "$LOGFILE" 2>/dev/null || true
    publish_startup_failure remote_relay_ready "relay pre-ready dirty reader unavailable" || true
    if ! is_relay_running; then
      stop_stale_processes
    fi
    return 1
  fi
  boot_stage remote_relay_ready

  if ! wait_boot_inputs_ready; then
    echo "v5_ui_relay backend/profile/publisher barrier failed" >&2
    publish_startup_failure boot_inputs_ready "backend/profile/publisher barrier failed" || true
    stop_stale_processes
    return 1
  fi
  boot_stage boot_inputs_ready

  V5_PROJECT_ROOT="$PROJECT_ROOT" V5_UI_REMOTE_INPUT="$REMOTE_INPUT" \
    setsid taskset -c 1 nice -n "$UI_INPUT_NICE" "$UI_DAEMON" --serve >>"$UI_BOOT_LOG" 2>&1 &
  echo "$!" >"$UI_PIDFILE"
  if ! record_process_identity "$(read_pidfile "$UI_PIDFILE")" "$UI_STARTFILE"; then
    echo "v5_ui_shell process identity unavailable" >&2
    publish_startup_failure ui_process_spawned "UI process identity unavailable" || true
    stop_ui_only
    return 1
  fi
  boot_stage ui_process_spawned
  sleep 0.1
  if ! is_ui_running; then
    echo "v5_ui_shell failed to start" >&2
    tail -n 40 "$UI_BOOT_LOG" 2>/dev/null || true
    publish_startup_failure ui_process_spawned "UI process exited before cache preparation" || true
    stop_ui_only
    return 1
  fi

  if ! "$BOOT_READY" \
      --ui-pid "$(cat "$UI_PIDFILE")" \
      --ui-log "$UI_BOOT_LOG" \
      --ready-path "$UI_READY_PATH" \
      --publisher-snapshot-path "$PUBLISHER_SNAPSHOT_PATH" \
      --backend-readiness-probe "$BACKEND_READINESS_PROBE" \
      --expected-ini "$PROJECT_ROOT/linuxcnc/ini/v5_bus.ini" \
      --diagnostics-url "http://127.0.0.1:$PORT/remote/diagnostics" \
      --startup-instance-id "$STARTUP_INSTANCE_ID" \
      --failure-owner-role relay \
      --failure-owner-pid "$(read_pidfile "$PIDFILE")" \
      --failure-owner-start-ticks "$(read_startfile "$RELAY_STARTFILE")" \
      --failure-stage ui_ready_handshake \
      --width "$REMOTE_WIDTH" \
      --height "$REMOTE_HEIGHT" \
      --require-cpu-list 1 >>"$LOGFILE" 2>&1; then
    echo "v5 UI cache/first-frame ready handshake failed" >&2
    tail -n 80 "$UI_BOOT_LOG" "$LOGFILE" 2>/dev/null || true
    stop_ui_only
    rm -f "$PUBLISHER_SNAPSHOT_PATH"
    return 1
  fi
  if ! wget -q -O /tmp/v5_ui_ready_info.json "http://127.0.0.1:$PORT/remote/info"; then
    echo "v5 remote UI remained gated after ready metadata" >&2
    publish_startup_failure remote_info_ready "relay rejected committed UI ready identity" || true
    stop_ui_only
    rm -f "$PUBLISHER_SNAPSHOT_PATH"
    return 1
  fi
  rm -f "$PUBLISHER_SNAPSHOT_PATH"
  boot_stage ui_ready
  set_non_microkernel_affinity "$(read_pidfile "$UI_PIDFILE")"
  set_non_microkernel_affinity "$(read_pidfile "$PIDFILE")"
  set_display_irq_affinity
  echo "v5_ui_relay started relay_pid=$(read_pidfile "$PIDFILE") ui_pid=$(read_pidfile "$UI_PIDFILE") port=$PORT bind=$REMOTE_BIND allow_cidrs=$REMOTE_ALLOW_CIDRS remote_input=$REMOTE_INPUT project_root=$PROJECT_ROOT ready=$UI_READY_PATH"
  return 0
}

stop_pidfile() {
  file="$1"
  startfile="$2"
  expected_arg="$3"
  label="$4"
  pid=$(read_pidfile "$file" 2>/dev/null || true)
  if ! process_identity_matches "$file" "$startfile" "$expected_arg"; then
    rm -f "$file" "$startfile"
    return 0
  fi
  kill "$pid" 2>/dev/null || true
  i=0
  while process_identity_matches "$file" "$startfile" "$expected_arg" && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if process_identity_matches "$file" "$startfile" "$expected_arg"; then
    kill -KILL "$pid" 2>/dev/null || true
    sleep 0.2
  fi
  if process_identity_matches "$file" "$startfile" "$expected_arg"; then
    echo "$label did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$file" "$startfile"
  echo "$label stopped pid=$pid"
}

stop_service() {
  if ! is_ui_running && ! is_relay_running; then
    rm -f "$PIDFILE" "$UI_PIDFILE" "$RELAY_STARTFILE" "$UI_STARTFILE" \
      "$UI_READY_PATH" "$PUBLISHER_SNAPSHOT_PATH"
    stop_stale_processes
    echo "v5_ui_relay not running"
    return 0
  fi
  stop_pidfile "$PIDFILE" "$RELAY_STARTFILE" "$RELAY_DAEMON" "v5_remote_ui_relay"
  stop_pidfile "$UI_PIDFILE" "$UI_STARTFILE" "$UI_DAEMON" "v5_ui_shell"
  stop_stale_processes
  rm -f "$UI_READY_PATH" "$PUBLISHER_SNAPSHOT_PATH"
}

case "${1:-}" in
  start) start_service ;;
  stop) stop_service ;;
  restart) stop_service; start_service ;;
  status)
    if is_running; then
      echo "v5_ui_relay running relay_pid=$(read_pidfile "$PIDFILE") ui_pid=$(read_pidfile "$UI_PIDFILE") port=$PORT bind=$REMOTE_BIND allow_cidrs=$REMOTE_ALLOW_CIDRS remote_input=$REMOTE_INPUT project_root=$PROJECT_ROOT ready=$UI_READY_PATH"
    elif [ -s "$UI_READY_PATH" ] && grep -q '"schema":"v5.ui_failure.v1"' "$UI_READY_PATH" && \
         grep -q "\"boot_id\":\"$(cat /proc/sys/kernel/random/boot_id 2>/dev/null || true)\"" "$UI_READY_PATH"; then
      echo "v5_ui_relay failed failure_state=$UI_READY_PATH"
      exit 1
    else
      echo "v5_ui_relay not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
