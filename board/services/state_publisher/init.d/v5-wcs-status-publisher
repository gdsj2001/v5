#!/bin/sh
set -eu

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

DAEMON=/usr/libexec/8ax/v5_wcs_status_publisher.py
PIDFILE=/run/8ax/v5_wcs_status_publisher.pid
LOGFILE=/run/8ax/v5_wcs_status_publisher.log
STATUS_PATH=${V5_WCS_STATUS_PATH:-/dev/shm/v5_native_wcs_status.bin}
LINUXCNC_INI=${V5_LINUXCNC_INI:-/opt/8ax/v5/linuxcnc/ini/v5_bus.ini}
MODAL_TOOL_PATH=${V5_MODAL_TOOL_STATUS_PATH:-/dev/shm/v5_native_modal_tool_status.bin}
OPERATOR_ERROR_PATH=${V5_OPERATOR_ERROR_STATUS_PATH:-/dev/shm/v5_native_operator_error_status.bin}
OPERATOR_ERROR_MAP=${V5_OPERATOR_ERROR_MAP:-/opt/8ax/v5/config/ui/v5_native_operator_error_map.tsv}
RETIRED_STATUS_PATHS="/run/8ax_v5_product_ui/v3_native_wcs_status.bin /run/8ax_v5_product_ui/v3_native_position_status.bin /run/8ax_v5_product_ui/v3_native_modal_tool_status.bin /run/8ax_v5_product_ui/v3_native_operator_error_status.bin"
INTERVAL_MS=${V5_WCS_STATUS_INTERVAL_MS:-200}
NON_MICROKERNEL_NICE=10
PYTHONPATH=/usr/lib/python3/dist-packages${PYTHONPATH:+:$PYTHONPATH}
LINUXCNC_PY_HOME=${V5_LINUXCNC_PY_HOME:-}
if [ -z "$LINUXCNC_PY_HOME" ]; then
  LINUXCNC_PY_HOME=$(awk -F: '$1 == "root" {print $6}' /etc/passwd 2>/dev/null || true)
fi
if [ -z "$LINUXCNC_PY_HOME" ] || [ ! -d "$LINUXCNC_PY_HOME" ]; then
  echo "v5 publisher missing root home for LinuxCNC Python: $LINUXCNC_PY_HOME" >&2
  exit 1
fi
HOME=$LINUXCNC_PY_HOME
export PYTHONPATH HOME

process_start_ticks() {
  stat_line=$(cat "/proc/$1/stat" 2>/dev/null) || return 1
  stat_tail=${stat_line##*) }
  set -- $stat_tail
  [ "$#" -ge 20 ] || return 1
  shift 19
  case "$1" in *[!0-9]*|'') return 1 ;; esac
  printf '%s\n' "$1"
}

read_pid_record() {
  [ -r "$PIDFILE" ] || return 1
  read -r pid pid_start extra <"$PIDFILE" || return 1
  [ -n "$pid" ] && [ -n "$pid_start" ] && [ -z "${extra:-}" ]
}

is_running() {
  read_pid_record || return 1
  [ "$(process_start_ticks "$pid" 2>/dev/null || true)" = "$pid_start" ]
}

start_service() {
  if is_running; then
    echo "v5_wcs_status_publisher already running pid=$(cat "$PIDFILE")"
    return 0
  fi
  test -x "$DAEMON"
  test -r "$OPERATOR_ERROR_MAP"
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  mkdir -p /run/8ax /run/8ax_v5_product_ui
  rm -f "$PIDFILE" "$STATUS_PATH" "$MODAL_TOOL_PATH" "$OPERATOR_ERROR_PATH" $RETIRED_STATUS_PATHS
  cd "$LINUXCNC_PY_HOME"
  setsid taskset -c 1 nice -n "$NON_MICROKERNEL_NICE" "$DAEMON" --path "$STATUS_PATH" --modal-tool-path "$MODAL_TOOL_PATH" --operator-error-path "$OPERATOR_ERROR_PATH" --operator-error-map "$OPERATOR_ERROR_MAP" --ini "$LINUXCNC_INI" --interval-ms "$INTERVAL_MS" >>"$LOGFILE" 2>&1 &
  pid=$!
  pid_start=$(process_start_ticks "$pid") || { kill "$pid" 2>/dev/null || true; return 1; }
  printf '%s %s\n' "$pid" "$pid_start" >"$PIDFILE"
  echo "v5_wcs_status_publisher spawned pid=$pid start_ticks=$pid_start path=$STATUS_PATH modal_tool_path=$MODAL_TOOL_PATH operator_error_path=$OPERATOR_ERROR_PATH interval_ms=$INTERVAL_MS home=$LINUXCNC_PY_HOME"
}

stop_service() {
  if ! is_running; then
    rm -f "$PIDFILE" "$OPERATOR_ERROR_PATH" $RETIRED_STATUS_PATHS
    echo "v5_wcs_status_publisher not running"
    return 0
  fi
  read_pid_record
  kill "$pid" 2>/dev/null || true
  i=0
  while kill -0 "$pid" 2>/dev/null && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null; then
    echo "v5_wcs_status_publisher did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$PIDFILE" "$OPERATOR_ERROR_PATH" $RETIRED_STATUS_PATHS
  echo "v5_wcs_status_publisher stopped pid=$pid"
}

case "${1:-}" in
  start)
    start_service
    ;;
  stop)
    stop_service
    ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    if is_running; then
      echo "v5_wcs_status_publisher running pid=$pid start_ticks=$pid_start"
    else
      echo "v5_wcs_status_publisher not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
