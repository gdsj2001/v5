#!/bin/sh
set -eu

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

DAEMON=/usr/libexec/8ax/v5_position_status_publisher.py
PIDFILE=/run/8ax/v5_position_status_publisher.pid
LOCKFILE=/run/8ax/v5_position_status_publisher.lock
LOGFILE=/run/8ax/v5_position_status_publisher.log
STATUS_PATH=${V5_POSITION_STATUS_PATH:-/dev/shm/v5_native_position_status.bin}
INTERVAL_MS=${V5_POSITION_STATUS_INTERVAL_MS:-33}
POSITION_NICE=0
RUNTIME_MODULE_ROOT=/usr/libexec/8ax
PYTHONPATH=$RUNTIME_MODULE_ROOT:/usr/lib/python3/dist-packages${PYTHONPATH:+:$PYTHONPATH}
export PYTHONPATH

read_lock_owner() {
  [ -r "$LOCKFILE" ] || return 1
  read -r OWNER_PID OWNER_START OWNER_WRITER <"$LOCKFILE" || return 1
  case "$OWNER_PID:$OWNER_START:$OWNER_WRITER" in
    *[!0-9:]*|::*|*::*|:) return 1 ;;
  esac
  [ "$OWNER_WRITER" -gt 0 ] 2>/dev/null || return 1
}

owner_is_live() {
  read_lock_owner || return 1
  [ -r "/proc/$OWNER_PID/stat" ] || return 1
  [ "$(awk '{print $22}' "/proc/$OWNER_PID/stat" 2>/dev/null || true)" = "$OWNER_START" ] || return 1
  tr '\000' '\n' <"/proc/$OWNER_PID/cmdline" 2>/dev/null | grep -Fqx "$DAEMON" || return 1
  ! flock -n "$LOCKFILE" true 2>/dev/null
}

position_block_matches_owner() {
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$STATUS_PATH" "$OWNER_WRITER" <<'PY'
import sys
from v5_wcs_status_codec import POSITION_BLOCK_STRUCT, POSITION_MAGIC, POSITION_STATUS_VERSION, crc32_like

try:
    payload = open(sys.argv[1], 'rb').read()
    values = POSITION_BLOCK_STRUCT.unpack(payload)
except (OSError, ValueError, TypeError):
    raise SystemExit(1)
if (len(payload) != POSITION_BLOCK_STRUCT.size or values[0] != POSITION_MAGIC or
        values[1] != POSITION_STATUS_VERSION or values[2] != POSITION_BLOCK_STRUCT.size or
        values[5] != int(sys.argv[2]) or values[-2] != crc32_like(payload[:-8])):
    raise SystemExit(1)
PY
}

start_service() {
  if owner_is_live; then
    echo "v5_position_status_publisher already running pid=$OWNER_PID writer=$OWNER_WRITER"
    return 0
  fi
  test -x "$DAEMON"
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  command -v flock >/dev/null 2>&1
  mkdir -p /run/8ax
  rm -f "$PIDFILE"
  rm -f "$STATUS_PATH"
  setsid taskset -c 1 nice -n "$POSITION_NICE" "$DAEMON" \
    --path "$STATUS_PATH" --interval-ms "$INTERVAL_MS" >>"$LOGFILE" 2>&1 &
  launched_pid=$!
  echo "v5_position_status_publisher spawned pid=$launched_pid path=$STATUS_PATH interval_ms=$INTERVAL_MS"
}

stop_service() {
  if ! owner_is_live; then
    rm -f "$PIDFILE"
    echo "v5_position_status_publisher not running"
    return 0
  fi
  pid=$OWNER_PID
  start=$OWNER_START
  kill "$pid"
  i=0
  while [ -r "/proc/$pid/stat" ] && [ "$(awk '{print $22}' "/proc/$pid/stat" 2>/dev/null || true)" = "$start" ] && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if [ -r "/proc/$pid/stat" ] && [ "$(awk '{print $22}' "/proc/$pid/stat" 2>/dev/null || true)" = "$start" ]; then
    echo "v5_position_status_publisher did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$PIDFILE"
  rm -f "$STATUS_PATH"
  echo "v5_position_status_publisher stopped pid=$pid"
}

case "${1:-}" in
  start)
    start_service
    ;;
  stop)
    stop_service
    ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    if owner_is_live && position_block_matches_owner; then
      echo "v5_position_status_publisher running pid=$OWNER_PID writer=$OWNER_WRITER"
    else
      echo "v5_position_status_publisher not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
