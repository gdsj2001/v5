#!/bin/sh
set -eu

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

DAEMON=/usr/libexec/8ax/v5_position_status_publisher.py
PIDFILE=/run/8ax/v5_position_status_publisher.pid
LOGFILE=/run/8ax/v5_position_status_publisher.log
STATUS_PATH=${V5_POSITION_STATUS_PATH:-/dev/shm/v5_native_position_status.bin}
INTERVAL_MS=${V5_POSITION_STATUS_INTERVAL_MS:-33}
POSITION_NICE=0
PYTHONPATH=/usr/lib/python3/dist-packages${PYTHONPATH:+:$PYTHONPATH}
export PYTHONPATH

is_running() {
  [ -r "$PIDFILE" ] || return 1
  pid=$(cat "$PIDFILE" 2>/dev/null || true)
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

set_position_affinity() {
  pid="$1"
  command -v taskset >/dev/null 2>&1 || return 1
  command -v renice >/dev/null 2>&1 || return 1
  taskset -a -pc 1 "$pid" >>"$LOGFILE" 2>&1 || return 1
  for task in /proc/"$pid"/task/[0-9]*; do
    [ -r "$task/stat" ] || return 1
    tid=${task##*/}
    renice -n "$POSITION_NICE" -p "$tid" >>"$LOGFILE" 2>&1 || return 1
    [ "$(awk '{print $19}' "$task/stat" 2>/dev/null || true)" = "$POSITION_NICE" ] || return 1
  done
}

wait_position_hal_ready() {
  i=0
  while [ "$i" -lt 120 ]; do
    ready=1
    for pin in \
      joint.0.pos-fb \
      joint.4.pos-cmd \
      motion.current-vel \
      spindle.0.speed-cmd-rps \
      motion.feed-override \
      spindle.0.override \
      v5-native-hal-owner.home-table-mapping-valid
    do
      halcmd getp "$pin" >/dev/null 2>&1 || ready=0
    done
    [ "$ready" -eq 0 ] || return 0
    i=$((i + 1))
    sleep 0.1
  done
  echo "v5_position_status_publisher HAL display sources not ready" >>"$LOGFILE"
  return 1
}

start_service() {
  if is_running; then
    echo "v5_position_status_publisher already running pid=$(cat "$PIDFILE")"
    return 0
  fi
  test -x "$DAEMON"
  command -v halcmd >/dev/null 2>&1
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  command -v renice >/dev/null 2>&1
  mkdir -p /run/8ax
  rm -f "$PIDFILE" "$STATUS_PATH"
  wait_position_hal_ready
  setsid taskset -c 1 nice -n "$POSITION_NICE" "$DAEMON" \
    --path "$STATUS_PATH" --interval-ms "$INTERVAL_MS" >>"$LOGFILE" 2>&1 &
  echo "$!" >"$PIDFILE"
  sleep 1
  if is_running; then
    set_position_affinity "$(cat "$PIDFILE")"
    test -s "$STATUS_PATH"
    echo "v5_position_status_publisher started pid=$(cat "$PIDFILE") path=$STATUS_PATH interval_ms=$INTERVAL_MS"
    return 0
  fi
  echo "v5_position_status_publisher failed to start" >&2
  tail -n 20 "$LOGFILE" 2>/dev/null || true
  return 1
}

stop_service() {
  if ! is_running; then
    rm -f "$PIDFILE" "$STATUS_PATH"
    echo "v5_position_status_publisher not running"
    return 0
  fi
  pid=$(cat "$PIDFILE")
  kill "$pid" 2>/dev/null || true
  i=0
  while kill -0 "$pid" 2>/dev/null && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null; then
    echo "v5_position_status_publisher did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$PIDFILE" "$STATUS_PATH"
  echo "v5_position_status_publisher stopped pid=$pid"
}

case "${1:-}" in
  start)
    start_service
    ;;
  stop)
    stop_service
    ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    if is_running; then
      echo "v5_position_status_publisher running pid=$(cat "$PIDFILE")"
    else
      echo "v5_position_status_publisher not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
