#!/bin/sh
set -eu

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

DAEMON=/usr/libexec/8ax/v5_state_publisher
PIDFILE=/run/8ax/v5_state_publisher.pid
LOGFILE=/run/8ax/v5_state_publisher.log
STATUS_PATH=${V5_STATUS_SHM_PATH:-/dev/shm/v3_status_shm}
INTERVAL_MS=${V5_STATE_PUBLISHER_INTERVAL_MS:-30}
NON_MICROKERNEL_NICE=10

is_running() {
  [ -r "$PIDFILE" ] || return 1
  pid=$(cat "$PIDFILE" 2>/dev/null || true)
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

set_non_microkernel_affinity() {
  pid="$1"
  [ -n "$pid" ] || return 0
  command -v taskset >/dev/null 2>&1 || return 1
  command -v renice >/dev/null 2>&1 || return 1
  taskset -a -pc 1 "$pid" >>"$LOGFILE" 2>&1 || return 1
  for task in /proc/"$pid"/task/[0-9]*; do
    [ -r "$task/stat" ] || return 1
    tid=${task##*/}
    renice -n "$NON_MICROKERNEL_NICE" -p "$tid" >>"$LOGFILE" 2>&1 || return 1
    [ "$(awk '{print $19}' "$task/stat" 2>/dev/null || true)" = "$NON_MICROKERNEL_NICE" ] || return 1
  done
}

start_service() {
  if is_running; then
    echo "v5_state_publisher already running pid=$(cat "$PIDFILE")"
    return 0
  fi
  test -x "$DAEMON"
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  command -v renice >/dev/null 2>&1
  mkdir -p /run/8ax
  rm -f "$PIDFILE"
  setsid taskset -c 1 nice -n "$NON_MICROKERNEL_NICE" "$DAEMON" --path "$STATUS_PATH" --interval-ms "$INTERVAL_MS" >>"$LOGFILE" 2>&1 &
  echo "$!" >"$PIDFILE"
  sleep 1
  if is_running; then
    set_non_microkernel_affinity "$(cat "$PIDFILE")"
    echo "v5_state_publisher started pid=$(cat "$PIDFILE") path=$STATUS_PATH interval_ms=$INTERVAL_MS"
    return 0
  fi
  echo "v5_state_publisher failed to start" >&2
  tail -n 20 "$LOGFILE" 2>/dev/null || true
  return 1
}

stop_service() {
  if ! is_running; then
    rm -f "$PIDFILE"
    echo "v5_state_publisher not running"
    return 0
  fi
  pid=$(cat "$PIDFILE")
  kill "$pid" 2>/dev/null || true
  i=0
  while kill -0 "$pid" 2>/dev/null && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null; then
    echo "v5_state_publisher did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$PIDFILE"
  echo "v5_state_publisher stopped pid=$pid"
}

case "${1:-}" in
  start)
    start_service
    ;;
  stop)
    stop_service
    ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    if is_running; then
      echo "v5_state_publisher running pid=$(cat "$PIDFILE")"
    else
      echo "v5_state_publisher not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
