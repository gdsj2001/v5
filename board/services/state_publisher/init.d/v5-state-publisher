#!/bin/sh
set -eu

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

DAEMON=/usr/libexec/8ax/v5_state_publisher
PIDFILE=/run/8ax/v5_state_publisher.pid
LOGFILE=/run/8ax/v5_state_publisher.log
STATUS_PATH=${V5_STATUS_SHM_PATH:-/dev/shm/v3_status_shm}
INTERVAL_MS=${V5_STATE_PUBLISHER_INTERVAL_MS:-33}
NON_MICROKERNEL_NICE=10

process_start_ticks() {
  stat_line=$(cat "/proc/$1/stat" 2>/dev/null) || return 1
  stat_tail=${stat_line##*) }
  set -- $stat_tail
  [ "$#" -ge 20 ] || return 1
  shift 19
  case "$1" in *[!0-9]*|'') return 1 ;; esac
  printf '%s\n' "$1"
}

read_pid_record() {
  [ -r "$PIDFILE" ] || return 1
  read -r pid pid_start extra <"$PIDFILE" || return 1
  [ -n "$pid" ] && [ -n "$pid_start" ] && [ -z "${extra:-}" ]
}

is_running() {
  read_pid_record || return 1
  [ "$(process_start_ticks "$pid" 2>/dev/null || true)" = "$pid_start" ]
}

start_service() {
  if is_running; then
    echo "v5_state_publisher already running pid=$(cat "$PIDFILE")"
    return 0
  fi
  test -x "$DAEMON"
  command -v taskset >/dev/null 2>&1
  command -v nice >/dev/null 2>&1
  mkdir -p /run/8ax
  rm -f "$PIDFILE"
  setsid taskset -c 1 nice -n "$NON_MICROKERNEL_NICE" "$DAEMON" --path "$STATUS_PATH" --interval-ms "$INTERVAL_MS" >>"$LOGFILE" 2>&1 &
  pid=$!
  pid_start=$(process_start_ticks "$pid") || { kill "$pid" 2>/dev/null || true; return 1; }
  printf '%s %s\n' "$pid" "$pid_start" >"$PIDFILE"
  echo "v5_state_publisher spawned pid=$pid start_ticks=$pid_start path=$STATUS_PATH interval_ms=$INTERVAL_MS"
}

stop_service() {
  if ! is_running; then
    rm -f "$PIDFILE"
    echo "v5_state_publisher not running"
    return 0
  fi
  read_pid_record
  kill "$pid" 2>/dev/null || true
  i=0
  while kill -0 "$pid" 2>/dev/null && [ "$i" -lt 50 ]; do
    i=$((i + 1))
    sleep 0.1
  done
  if kill -0 "$pid" 2>/dev/null; then
    echo "v5_state_publisher did not stop pid=$pid" >&2
    return 1
  fi
  rm -f "$PIDFILE"
  echo "v5_state_publisher stopped pid=$pid"
}

case "${1:-}" in
  start)
    start_service
    ;;
  stop)
    stop_service
    ;;
  restart)
    stop_service
    start_service
    ;;
  status)
    if is_running; then
      echo "v5_state_publisher running pid=$pid start_ticks=$pid_start"
    else
      echo "v5_state_publisher not running"
      exit 1
    fi
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
