#!/bin/sh
set -eu

bind_service_init_to_cpu1() {
  cpu_list=
  while read -r key value rest; do
    if [ "$key" = "Cpus_allowed_list:" ]; then
      cpu_list=${value:-}
      break
    fi
  done <"/proc/$$/status"
  [ "$cpu_list" = "1" ] && return 0
  [ -x /usr/bin/taskset ] || {
    echo "taskset missing; Command Gate init cannot exclude CPU0" >&2
    return 1
  }
  exec /usr/bin/taskset -c 1 "$0" "$@"
}
bind_service_init_to_cpu1 "$@"

LD_BIND_NOW=1
export LD_BIND_NOW
ulimit -l unlimited 2>/dev/null || true

RUN_DIR=/run/8ax
RTAPI_FIFO_PATH=$RUN_DIR/v5_rtapi_fifo
REQUESTED_MODE_FILE=${V5_REQUESTED_MODE_FILE:-/opt/8ax/v5/config/settings/self_parameter_table.tsv}
BUS_LINUXCNC_INI=/opt/8ax/v5/linuxcnc/ini/v5_bus.ini
PULSE_LINUXCNC_INI=/opt/8ax/v5/linuxcnc/ini/v5_pulse.ini
LINUXCNC_INI=
REQUESTED_DRIVER_MODE=
SETTINGS_RUNTIME=/opt/8ax/phase0_bus5/settings_runtime.json
SETTINGS_PROJECT_ROOT=/opt/8ax/v5
PULSE_CONTRACT=/opt/8ax/v5/linuxcnc/components/step_ip_v1_5.contract.json
LINUXCNC_LOG=$RUN_DIR/v5_linuxcnc.log
LINUXCNC_PID=$RUN_DIR/v5_linuxcnc.pid
LINUXCNCRSH_LOG=$RUN_DIR/v5_linuxcncrsh.log
LINUXCNCRSH_PID=$RUN_DIR/v5_linuxcncrsh.pid
COMMAND_GATE_LOG=$RUN_DIR/v5_command_gate.log
COMMAND_GATE_PID=$RUN_DIR/v5_command_gate.pid
COMMAND_GATE_SOCKET=/run/8ax_v5_product_ui/v5_command_gate.sock
BACKEND_READINESS_PROBE=/usr/libexec/8ax/v5_backend_readiness_probe
BACKEND_READINESS_LOG=$RUN_DIR/v5_backend_readiness.log
STARTUP_TIMING_LOG=$RUN_DIR/v5_startup_timing.tsv
LINUXCNCRSH_PORT=${V5_LINUXCNCRSH_PORT:-5007}
LINUXCNCRSH_CONNECTPW=${V5_LINUXCNCRSH_CONNECTPW:-EMC}
NC_PATH=/opt/8ax/v5/linuxcnc/nc
MICROKERNEL_NON_RT_NICE=-5
MANAGEMENT_NICE=15
MANAGEMENT_IFACE=eth0
ETHERCAT_IFACE=eth1
ETHERCAT_CONFIG=/opt/8ax/v5/linuxcnc/hal/ethercat-conf-2ms.xml
ETHERCAT_LIFECYCLE_LIB=${V5_ETHERCAT_LIFECYCLE_LIB:-/usr/libexec/8ax/v5_ethercat_backend_lifecycle.sh}
ETHERCAT_ATTACH_FAULT_BASELINE=/run/v5_ethercat_attach_fault_baseline

read_requested_driver_mode() {
  [ -r "$REQUESTED_MODE_FILE" ] || {
    echo "motion driver requested owner missing: $REQUESTED_MODE_FILE" >&2
    return 1
  }
  requested_value=$(awk -F '\t' '
    $1 == "SETTINGS" && $2 == "bus_pulse_setting" {
      count += 1
      value = $3
    }
    END {
      if (count != 1) exit 2
      sub(/\r$/, "", value)
      print value
    }
  ' "$REQUESTED_MODE_FILE") || {
    echo "motion driver requested owner must contain exactly one SETTINGS/bus_pulse_setting row" >&2
    return 1
  }
  case "$requested_value" in
    bus|BUS|Bus|ethercat|EtherCAT|总线)
      printf '%s\n' bus
      ;;
    pulse|PULSE|Pulse|stepdir|step_dir|step/dir|脉冲)
      printf '%s\n' pulse
      ;;
    *)
      echo "motion driver requested value is unknown: $requested_value" >&2
      return 1
      ;;
  esac
}

pulse_contract_runtime_selectable() {
  [ -r "$PULSE_CONTRACT" ] || return 1
  grep -Eq '"status"[[:space:]]*:[[:space:]]*"runtime_selectable"' "$PULSE_CONTRACT"
}

select_requested_backend() {
  REQUESTED_DRIVER_MODE=$(read_requested_driver_mode) || return 1
  case "$REQUESTED_DRIVER_MODE" in
    bus)
      LINUXCNC_INI=$BUS_LINUXCNC_INI
      ;;
    pulse)
      LINUXCNC_INI=$PULSE_LINUXCNC_INI
      ;;
    *)
      return 1
      ;;
  esac
  [ -r "$LINUXCNC_INI" ] || {
    echo "selected LinuxCNC INI missing: $LINUXCNC_INI" >&2
    return 1
  }
  echo "motion driver selected requested=$REQUESTED_DRIVER_MODE ini=$LINUXCNC_INI"
}

select_running_backend_for_stop() {
  for cmdline in /proc/[0-9]*/cmdline; do
    [ -r "$cmdline" ] || continue
    command_line=$(tr '\000' ' ' <"$cmdline" 2>/dev/null || true)
    case "$command_line" in
      *milltask*"$BUS_LINUXCNC_INI"*)
        REQUESTED_DRIVER_MODE=bus
        LINUXCNC_INI=$BUS_LINUXCNC_INI
        return 0
        ;;
      *milltask*"$PULSE_LINUXCNC_INI"*)
        REQUESTED_DRIVER_MODE=pulse
        LINUXCNC_INI=$PULSE_LINUXCNC_INI
        return 0
        ;;
    esac
  done
  select_requested_backend
}

prepare_selected_transport() {
  case "$REQUESTED_DRIVER_MODE" in
    bus)
      if ! ethercat master >/dev/null 2>&1; then
        [ -x /etc/init.d/ethercat ] || {
          echo "EtherCAT init owner missing" >&2
          return 1
        }
        /etc/init.d/ethercat start || return 1
      fi
      wait_ethercat_transport_scanned || return 1
      capture_ethercat_attach_fault_baseline || return 1
      ;;
    pulse)
      if ethercat master >/dev/null 2>&1; then
        /etc/init.d/ethercat stop || return 1
      fi
      pulse_contract_runtime_selectable || {
        echo "Pulse requested but contract is not runtime_selectable; refusing both motion backends" >&2
        return 1
      }
      if ethercat master >/dev/null 2>&1; then
        echo "Pulse requested but EtherCAT master remained active" >&2
        return 1
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

if [ "${1:-}" = requested-mode ]; then
  read_requested_driver_mode
  exit $?
fi

runtime_prepare() {
  mkdir -p "$RUN_DIR" /run/8ax_v5_product_ui /opt/8ax/v5/linuxcnc/var "$NC_PATH" /opt/8ax/v5/linuxcnc/remap_subs || return 1
  chown petalinux:petalinux "$RUN_DIR" /run/8ax_v5_product_ui 2>/dev/null || true
  chown -R petalinux:petalinux /opt/8ax/v5/linuxcnc/var "$NC_PATH" /opt/8ax/v5/linuxcnc/remap_subs 2>/dev/null || true
}

backend_running() {
  pidof linuxcncsvr >/dev/null 2>&1 && pidof milltask >/dev/null 2>&1
}

backend_residue_running() {
  pidof linuxcncsvr >/dev/null 2>&1 && return 0
  pidof milltask >/dev/null 2>&1 && return 0
  pidof io >/dev/null 2>&1 && return 0
  pidof rtapi_app >/dev/null 2>&1 && return 0
  halcmd show thread 2>/dev/null | grep -q 'servo-thread' && return 0
  return 1
}

[ -r "$ETHERCAT_LIFECYCLE_LIB" ] || {
  echo "EtherCAT lifecycle owner missing: $ETHERCAT_LIFECYCLE_LIB" >&2
  exit 1
}
. "$ETHERCAT_LIFECYCLE_LIB"

gate_running() {
  [ -r "$LINUXCNCRSH_PID" ] || return 1
  pid=$(cat "$LINUXCNCRSH_PID" 2>/dev/null || true)
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

native_gate_running() {
  [ -r "$COMMAND_GATE_PID" ] || return 1
  pid=$(cat "$COMMAND_GATE_PID" 2>/dev/null || true)
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null && [ -S "$COMMAND_GATE_SOCKET" ]
}

startup_monotonic_ns() {
  awk '{printf "%.0f\n", $1 * 1000000000}' /proc/uptime 2>/dev/null
}

record_startup_event() {
  event_name="$1"
  event_ns=${2:-}
  [ -n "$event_ns" ] || event_ns=$(startup_monotonic_ns) || return 1
  printf '%s\t%s\n' "$event_name" "$event_ns" >>"$STARTUP_TIMING_LOG"
}

record_native_readiness_events() {
  [ -r "$BACKEND_READINESS_LOG" ] || return 1
  awk '
    {
      for (i = 1; i <= NF; ++i) {
        split($i, pair, "=")
        if (pair[1] == "first_full_wkc" ||
            pair[1] == "dc_fresh_pair_ready" ||
            pair[1] == "cpu_contract_ready" ||
            pair[1] == "backend_ready_published") {
          value[pair[1]] = pair[2]
        }
      }
    }
    END {
      names[1] = "first_full_wkc"
      names[2] = "dc_fresh_pair_ready"
      names[3] = "cpu_contract_ready"
      names[4] = "backend_ready_published"
      for (i = 1; i <= 4; ++i) {
        name = names[i]
        if (!(name in value) || value[name] == "0") exit 2
        print name "\t" value[name]
      }
    }
  ' "$BACKEND_READINESS_LOG" >>"$STARTUP_TIMING_LOG"
}

backend_readiness_require() {
  target="$1"
  [ -x "$BACKEND_READINESS_PROBE" ] || return 1
  "$BACKEND_READINESS_PROBE" --require "$target"
}

backend_readiness_require_transaction() {
  [ -r "$BACKEND_READINESS_LOG" ] || return 1
  identity=$(awk '
    {
      for (i = 1; i <= NF; ++i) {
        split($i, pair, "=")
        if (pair[1] == "generation") generation = pair[2]
        else if (pair[1] == "owner_pid") owner_pid = pair[2]
        else if (pair[1] == "owner_start_ticks") owner_start_ticks = pair[2]
      }
    }
    END {
      if (!generation || !owner_pid || !owner_start_ticks) exit 2
      print generation, owner_pid, owner_start_ticks
    }
  ' "$BACKEND_READINESS_LOG") || return 1
  set -- $identity
  [ "$#" -eq 3 ] || return 1
  "$BACKEND_READINESS_PROBE" --require motion \
    --expect-generation "$1" \
    --expect-owner-pid "$2" \
    --expect-owner-start-ticks "$3"
}

arm_and_wait_backend_motion_ready() {
  [ -x "$BACKEND_READINESS_PROBE" ] || {
    echo "backend readiness probe missing: $BACKEND_READINESS_PROBE" >&2
    return 1
  }
  : >"$BACKEND_READINESS_LOG" || return 1
  if ! "$BACKEND_READINESS_PROBE" --arm --wait motion --timeout-ms 60000 \
      >"$BACKEND_READINESS_LOG" 2>&1; then
    cat "$BACKEND_READINESS_LOG" >&2 2>/dev/null || true
    return 1
  fi
  record_native_readiness_events || return 1
  cat "$BACKEND_READINESS_LOG"
}

set_command_gate_affinity() {
  pid="$1"
  [ -n "$pid" ] || return 0
  command -v taskset >/dev/null 2>&1 || return 1
  command -v renice >/dev/null 2>&1 || return 1
  if ! grep -qw 1 /sys/devices/system/cpu/online 2>/dev/null && ! grep -q '0-1' /sys/devices/system/cpu/online 2>/dev/null; then
    return 1
  fi
  taskset -a -pc 1 "$pid" >>"$COMMAND_GATE_LOG" 2>&1 || return 1
  for task in /proc/"$pid"/task/[0-9]*; do
    [ -r "$task/stat" ] || continue
    tid=${task##*/}
    if ! renice -n "$MICROKERNEL_NON_RT_NICE" -p "$tid" >>"$COMMAND_GATE_LOG" 2>&1; then
      [ ! -r "$task/stat" ] && continue
      return 1
    fi
    nice_value=$(awk '{print $19}' "$task/stat" 2>/dev/null || true)
    if [ "$nice_value" != "$MICROKERNEL_NON_RT_NICE" ]; then
      [ ! -r "$task/stat" ] && continue
      return 1
    fi
  done
  native_gate_running
}

set_management_process_affinity() {
  command -v taskset >/dev/null 2>&1 || return 0
  if ! grep -qw 1 /sys/devices/system/cpu/online 2>/dev/null && ! grep -q '0-1' /sys/devices/system/cpu/online 2>/dev/null; then
    return 0
  fi
  for name in dropbear sshd; do
    pids=$(pidof "$name" 2>/dev/null | xargs 2>/dev/null || true)
    [ -n "$pids" ] || continue
    for pid in $pids; do
      taskset -a -pc 1 "$pid" >>"$LINUXCNC_LOG" 2>&1 || true
      for task in /proc/"$pid"/task/[0-9]*; do
        [ -r "$task/stat" ] || continue
        renice -n "$MANAGEMENT_NICE" -p "${task##*/}" >>"$LINUXCNC_LOG" 2>&1 || true
      done
    done
  done
}

linuxcnc_non_realtime_pids() {
  collected=
  for name in linuxcncsvr milltask io linuxcncrsh v5_native_hal_owner; do
    pids=$(pidof "$name" 2>/dev/null) || return 1
    [ -n "$pids" ] || return 1
    collected="$collected $pids"
  done
  printf '%s\n' "${collected# }"
}

set_linuxcnc_non_realtime_priority() {
  command -v renice >/dev/null 2>&1 || {
    echo "renice missing; cannot protect LinuxCNC non-realtime motion paths on CPU1" >&2
    return 1
  }
  pids=$(linuxcnc_non_realtime_pids) || return 1
  [ -n "$pids" ] || return 1
  for pid in $pids; do
    for task in /proc/"$pid"/task/[0-9]*; do
      [ -r "$task/stat" ] || return 1
      renice -n "$MICROKERNEL_NON_RT_NICE" -p "${task##*/}" >>"$LINUXCNC_LOG" 2>&1 || return 1
    done
  done
  return 0
}

set_linuxcnc_non_realtime_affinity() {
  command -v taskset >/dev/null 2>&1 || {
    echo "taskset missing; cannot pin LinuxCNC non-realtime paths to CPU1" >&2
    return 1
  }
  if ! grep -qw 1 /sys/devices/system/cpu/online 2>/dev/null && ! grep -q '0-1' /sys/devices/system/cpu/online 2>/dev/null; then
    echo "CPU1 unavailable; cannot isolate LinuxCNC non-realtime paths" >&2
    return 1
  fi
  pids=$(linuxcnc_non_realtime_pids) || return 1
  [ -n "$pids" ] || return 1
  for pid in $pids; do
    taskset -a -pc 1 "$pid" >>"$LINUXCNC_LOG" 2>&1 || return 1
  done
  return 0
}

linuxcnc_realtime_pids() {
  pidof rtapi_app 2>/dev/null || true
}

linuxcnc_privileged_helpers_ok() {
  for helper in /usr/bin/rtapi_app /usr/bin/linuxcnc_module_helper; do
    [ -f "$helper" ] || return 1
    [ "$(stat -c '%u:%g:%a' "$helper" 2>/dev/null || true)" = "0:0:4755" ] || return 1
  done
  return 0
}

ethercat_kernel_threads() {
  for comm in /proc/[0-9]*/task/[0-9]*/comm; do
    [ -r "$comm" ] || continue
    name=$(cat "$comm" 2>/dev/null || true)
    case "$name" in
      EtherCAT*)
        task=${comm%/comm}
        echo "${task##*/}"
        ;;
    esac
  done
}

set_ethercat_realtime_affinity() {
  command -v taskset >/dev/null 2>&1 || {
    echo "taskset missing; cannot pin EtherCAT realtime threads to CPU0" >&2
    return 1
  }
  tids=$(ethercat_kernel_threads | xargs 2>/dev/null || true)
  [ -n "$tids" ] || return 1
  for tid in $tids; do
    taskset -pc 0 "$tid" >>"$LINUXCNC_LOG" 2>&1 || return 1
  done
  return 0
}

set_linuxcnc_realtime_affinity() {
  pids=$(linuxcnc_realtime_pids | xargs 2>/dev/null || true)
  [ -n "$pids" ] || return 1
  command -v taskset >/dev/null 2>&1 || {
    echo "taskset missing; cannot pin LinuxCNC RTAPI realtime threads to CPU0" >&2
    return 1
  }
  for pid in $pids; do
    taskset -a -pc 0 "$pid" >>"$LINUXCNC_LOG" 2>&1 || {
      for task in /proc/"$pid"/task/[0-9]*; do
        [ -e "$task" ] || continue
        taskset -pc 0 "${task##*/}" >>"$LINUXCNC_LOG" 2>&1 || return 1
      done
    }
  done
  set_ethercat_realtime_affinity || return 1
  return 0
}

wait_linuxcnc_process_set() {
  i=0
  while [ "$i" -lt 240 ]; do
    if backend_running &&
       linuxcnc_non_realtime_pids >/dev/null 2>&1 &&
       [ -n "$(linuxcnc_realtime_pids)" ]; then
      return 0
    fi
    if [ -r "$LINUXCNC_PID" ] && ! kill -0 "$(cat "$LINUXCNC_PID")" 2>/dev/null; then
      break
    fi
    i=$((i + 1))
    sleep 0.25
  done
  return 1
}

command_gate_pids() {
  for cmdline in /proc/[0-9]*/cmdline; do
    [ -r "$cmdline" ] || continue
    pid=${cmdline#/proc/}
    pid=${pid%/cmdline}
    [ "$pid" != "$$" ] || continue
    argv0=$(tr '\000' '\n' <"$cmdline" 2>/dev/null | sed -n '1p')
    case "$argv0" in
      /usr/libexec/8ax/v5_command_gate_server|v5_command_gate_server)
        echo "$pid"
        ;;
    esac
  done
}

kill_command_gate_processes() {
  pids=$(command_gate_pids | xargs 2>/dev/null || true)
  [ -n "$pids" ] || return 0
  kill $pids 2>/dev/null || true
  sleep 0.3
  pids=$(command_gate_pids | xargs 2>/dev/null || true)
  [ -n "$pids" ] || return 0
  kill -9 $pids 2>/dev/null || true
}

stop_native_gate() {
  if native_gate_running; then
    kill "$(cat "$COMMAND_GATE_PID")" 2>/dev/null || true
    sleep 0.3
  fi
  kill_command_gate_processes
  rm -f "$COMMAND_GATE_PID" "$COMMAND_GATE_SOCKET"
}

stop_gate() {
  stop_native_gate
  if gate_running; then
    kill "$(cat "$LINUXCNCRSH_PID")" 2>/dev/null || true
    sleep 0.3
  fi
  killall linuxcncrsh 2>/dev/null || true
  rm -f "$LINUXCNCRSH_PID"
}

stop_backend() {
  halcmd stop >/dev/null 2>&1 || true
  if ethercat master >/dev/null 2>&1; then
    quiesce_ethercat_slaves_before_release || {
      echo "EtherCAT slaves did not reach clean PREOP before master release" >&2
      return 1
    }
  elif backend_residue_running; then
    echo "EtherCAT master state is unreadable; refusing backend release without clean PREOP proof" >&2
    return 1
  fi
  su petalinux -c "RTAPI_FIFO_PATH='$RTAPI_FIFO_PATH' TCLLIBPATH=/usr/lib/tcltk /usr/bin/linuxcnc -r -k" >/dev/null 2>&1 || true
  halcmd unload all >/dev/null 2>&1 || true
  killall axis linuxcncsvr milltask io rtapi_app 2>/dev/null || true
  i=0
  while [ "$i" -lt 20 ]; do
    if ! backend_residue_running; then
      break
    fi
    halcmd stop >/dev/null 2>&1 || true
    halcmd unload all >/dev/null 2>&1 || true
    killall axis linuxcncsvr milltask io rtapi_app 2>/dev/null || true
    i=$((i + 1))
    sleep 0.25
  done
  rm -f "$LINUXCNC_PID"
  ethercat_backend_stopped || return 1
  rm -f "$ETHERCAT_ATTACH_FAULT_BASELINE"
}

start_backend() {
  select_requested_backend || return 1
  [ "$REQUESTED_DRIVER_MODE" = bus ] || {
    echo "Pulse runtime backend is not available in the current product contract" >&2
    return 1
  }
  runtime_prepare || return 1
  linuxcnc_privileged_helpers_ok || {
    echo "LinuxCNC privileged helpers must be root:root 4755; refusing backend start" >&2
    return 1
  }
  if backend_running; then
    if backend_readiness_require motion >/dev/null 2>&1; then
      echo "LinuxCNC and EtherCAT backend already ready"
      return 0
    fi
    echo "LinuxCNC processes exist without current readiness generation; rebuilding backend once" >&2
    stop_gate || return 1
    stop_backend || return 1
  fi
  if backend_residue_running; then
    stop_gate || return 1
    stop_backend || return 1
  fi
  if backend_residue_running; then
    echo "LinuxCNC backend residue remained before native status reset" >&2
    return 1
  fi
  prepare_selected_transport || return 1
  set_management_process_affinity
  rm -f \
    /dev/shm/v5_native_safety_latch.bin \
    /dev/shm/v5_native_rtcp_status.bin \
    /dev/shm/v5_native_g53_geometry_status.bin || return 1
  : >"$LINUXCNC_LOG" || return 1
  chown petalinux:petalinux "$LINUXCNC_LOG" 2>/dev/null || true
  su petalinux -c "cd /opt/8ax/v5/linuxcnc/ini && RTAPI_FIFO_PATH='$RTAPI_FIFO_PATH' TCLLIBPATH=/usr/lib/tcltk /usr/bin/linuxcnc -r '$LINUXCNC_INI' >>'$LINUXCNC_LOG' 2>&1" &
  linuxcnc_launcher_pid=$!
  if ! printf '%s\n' "$linuxcnc_launcher_pid" >"$LINUXCNC_PID"; then
    kill "$linuxcnc_launcher_pid" 2>/dev/null || true
    return 1
  fi
  record_startup_event linuxcnc_spawned || return 1
  if wait_linuxcnc_process_set &&
     set_linuxcnc_realtime_affinity &&
     set_linuxcnc_non_realtime_affinity &&
     set_linuxcnc_non_realtime_priority; then
    echo "LinuxCNC process set present; CPU placement applied once for native owner readback"
    return 0
  fi
  echo "LinuxCNC process set or one-time CPU placement failed" >&2
  tail -n 80 "$LINUXCNC_LOG" 2>/dev/null || true
  stop_backend || true
  return 1
}

start_native_gate() {
  stop_native_gate || return 1
  : >"$COMMAND_GATE_LOG" || return 1
  setsid /usr/libexec/8ax/v5_command_gate_server --socket "$COMMAND_GATE_SOCKET" --host 127.0.0.1 --port "$LINUXCNCRSH_PORT" --password "$LINUXCNCRSH_CONNECTPW" --timeout-ms 1000 --ini "$LINUXCNC_INI" --settings-project-root "$SETTINGS_PROJECT_ROOT" --settings-runtime "$SETTINGS_RUNTIME" --pulse-contract "$PULSE_CONTRACT" >>"$COMMAND_GATE_LOG" 2>&1 &
  command_gate_pid=$!
  if ! printf '%s\n' "$command_gate_pid" >"$COMMAND_GATE_PID"; then
    kill "$command_gate_pid" 2>/dev/null || true
    return 1
  fi
  i=0
  while [ "$i" -lt 40 ]; do
    if native_gate_running; then
      if ! set_command_gate_affinity "$(cat "$COMMAND_GATE_PID")"; then
        stop_native_gate
        return 1
      fi
      record_startup_event native_gate_socket_ready || return 1
      echo "v5_command_gate_server running pid=$(cat "$COMMAND_GATE_PID") socket=$COMMAND_GATE_SOCKET"
      return 0
    fi
    i=$((i + 1))
    sleep 0.25
  done
  echo "v5_command_gate_server failed to start" >&2
  cat "$COMMAND_GATE_LOG" 2>/dev/null || true
  return 1
}

start_gate() {
  i=0
  while [ "$i" -lt 40 ]; do
    pid=$(pidof linuxcncrsh 2>/dev/null || true)
    if [ -n "$pid" ]; then
      first_pid=$(printf '%s\n' "$pid" | awk '{print $1}') || return 1
      printf '%s\n' "$first_pid" >"$LINUXCNCRSH_PID" || return 1
      if /usr/libexec/8ax/v5_linuxcncrsh_probe --host 127.0.0.1 --port "$LINUXCNCRSH_PORT" --password "$LINUXCNCRSH_CONNECTPW" --timeout-ms 1000 >/tmp/v5_linuxcncrsh_init_probe.out 2>&1; then
        record_startup_event linuxcncrsh_probe_ready || return 1
        echo "linuxcncrsh running pid=$(cat "$LINUXCNCRSH_PID") port=$LINUXCNCRSH_PORT"
        return 0
      fi
    fi
    i=$((i + 1))
    sleep 0.25
  done
  echo "linuxcncrsh failed to start" >&2
  tail -n 80 "$LINUXCNC_LOG" 2>/dev/null || true
  cat /tmp/v5_linuxcncrsh_init_probe.out 2>/dev/null || true
  return 1
}

rollback_runtime_start() {
  rollback_rc=0
  stop_gate || rollback_rc=1
  stop_backend || rollback_rc=1
  if native_gate_running || gate_running || backend_residue_running; then
    echo "LinuxCNC runtime start rollback left an active layer" >&2
    rollback_rc=1
  fi
  return "$rollback_rc"
}

start_runtime_transaction() {
  : >"$STARTUP_TIMING_LOG" || return 1
  if ! start_backend; then
    echo "LinuxCNC runtime transaction failed at backend; rolling back" >&2
    rollback_runtime_start || echo "LinuxCNC runtime rollback incomplete" >&2
    return 1
  fi
  if ! start_gate; then
    echo "LinuxCNC runtime transaction failed at linuxcncrsh; rolling back" >&2
    rollback_runtime_start || echo "LinuxCNC runtime rollback incomplete" >&2
    return 1
  fi
  if ! arm_and_wait_backend_motion_ready; then
    echo "LinuxCNC runtime transaction failed at canonical backend readiness; rolling back" >&2
    rollback_runtime_start || echo "LinuxCNC runtime rollback incomplete" >&2
    return 1
  fi
  if ! start_native_gate; then
    echo "LinuxCNC runtime transaction failed at native Command Gate; rolling back" >&2
    rollback_runtime_start || echo "LinuxCNC runtime rollback incomplete" >&2
    return 1
  fi
  if ! backend_readiness_require_transaction >/dev/null 2>&1 ||
     ! gate_running || ! native_gate_running; then
    echo "LinuxCNC runtime transaction lost its final contract; rolling back" >&2
    rollback_runtime_start || echo "LinuxCNC runtime rollback incomplete" >&2
    return 1
  fi
  return 0
}

case "${1:-}" in
  start)
    start_runtime_transaction
    ;;
  stop)
    select_running_backend_for_stop >/dev/null 2>&1 || true
    stop_gate
    stop_backend
    ;;
  restart)
    select_running_backend_for_stop >/dev/null 2>&1 || true
    stop_gate
    stop_backend
    start_runtime_transaction
    ;;
  status)
    select_requested_backend >/dev/null
    [ "$REQUESTED_DRIVER_MODE" = bus ]
    backend_readiness_require motion >/dev/null 2>&1 && gate_running && native_gate_running
    ;;
  requested-mode)
    read_requested_driver_mode
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status|requested-mode}" >&2
    exit 2
    ;;
esac
