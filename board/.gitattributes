# VM/Linux source uses LF line endings.
* text=auto eol=lf

# Keep binary files opaque if any are intentionally tracked.
*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary
*.xz binary
*.zst binary
